{%- assign logo_url = booster_config.company_logo_url -%}

{%- if template.name == 'index' or template == "index" -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    "url": "https://{{ shop.domain }}",
    "description": {{ shop.description | json }},
    {%- unless logo_url == blank -%}
      "image": "{{ logo_url | remove: "\" }}",
      "logo": "{{ logo_url | remove: "\" }}",
    {%- else -%}
      "image": "https:{{ 'logo.png' | asset_url }}",
      "logo": "https:{{ 'logo.png' | asset_url }}",
    {%- endunless -%}
    "sameAs": ["{{ booster_config.same_as | join: '", "'}}"]
  }
</script>
{%- endif -%}

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": {{ shop.name | json }},
    "url": "{{ shop.secure_url }}",
    "potentialAction": {
      "@type": "SearchAction",
      "query-input": "required name=query",
      "target": "{{ shop.secure_url }}/search?q={query}"
    }
  }
</script>
{%- endif -%}

{%- if template.name == 'product' or template == 'product' -%}
{%- if booster_config.google_snippets_enabled -%}
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": {{ product.title | json }},
    "brand": {"@type": "Brand","name": {{ product.vendor | json }}},
    "sku": "{{ product.selected_or_first_available_variant.sku }}",
    "mpn": "{{ product.selected_or_first_available_variant.barcode }}",
    "description": {{ product.description | strip_html | json }},
    "url": "{{ shop.secure_url }}{{ product.url }}",
    {%- if product.featured_image -%}
    {%- assign image_size = product.featured_image.width | append: 'x' -%}
    "image": "https:{{ product.featured_image.src | img_url: image_size }}",
    {%- else -%}
    "image": "https:{{ product.images[0].src | img_url }}",
    {%- endif -%}
    "itemCondition": "https://schema.org/NewCondition",
    "offers": [
      {%- for variant in product.variants -%}
        {
          "@type": "Offer",
        {%- if shop.money_format contains 'amount_with_comma_separator' -%}
          "price": "{{ variant.price | money_without_currency | remove: '.' | replace: ',', '.' }}",
        {%- else -%}
           "price": "{{ variant.price | money_without_currency | remove: "," }}",
        {%- endif -%}
          "priceCurrency": "{{ shop.currency }}",
          "itemCondition": "https://schema.org/NewCondition",
          "url": "{{ shop.secure_url }}{{ variant.url }}",
          "sku": "{{ variant.sku }}",
          "mpn": "{{ variant.barcode }}",
          "availability" : "https://schema.org/{%- if variant.available -%}InStock{%- else -%}OutOfStock{%- endif -%}",
          "priceValidUntil": {{ "today" | date: '%s' | plus: 2592000 | date: "%Y-%m-%d" | json }},
        {%- if variant.barcode.size == 12 -%}
          "gtin12": "{{ variant.barcode }}"
        {%- elsif variant.barcode.size == 13 -%}
          "gtin13": "{{ variant.barcode }}"
        {%- else -%}
          "gtin14": "{{ variant.barcode }}"
        {%- endif -%}
{%- assign ba_refund_url = booster_config.custom_refund_policy_url -%}
{%- if ba_refund_url == blank -%}
  {%- assign ba_refund_url = shop.policies.refund_policy.url -%}
{%- endif -%}
{%- assign ba_shipping_url = booster_config.custom_shipping_policy_url -%}
{%- if ba_shipping_url == blank -%}
  {%- assign ba_shipping_url = shop.policies.shipping_policy.url -%}
{%- endif -%}
{%- if ba_refund_url != blank -%}
          ,"hasMerchantReturnPolicy": {
            "@type": "MerchantReturnPolicy",
            "applicableCountry": "{{ shop.address.country_code }}",
            "returnPolicyCountry": "{{ shop.address.country_code }}",
            "merchantReturnLink": "{{ ba_refund_url }}"
{%- if booster_config.return_policy_category == 'finite_window' -%}
            ,"returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow"
{%- if booster_config.merchant_return_days != blank -%}
            ,"merchantReturnDays": {{ booster_config.merchant_return_days }}
{%- endif -%}
{%- elsif booster_config.return_policy_category == 'unlimited_window' -%}
            ,"returnPolicyCategory": "https://schema.org/MerchantReturnUnlimitedWindow"
{%- elsif booster_config.return_policy_category == 'not_permitted' -%}
            ,"returnPolicyCategory": "https://schema.org/MerchantReturnNotPermitted"
{%- endif -%}
{%- if booster_config.return_fees == 'free_return' -%}
            ,"returnFees": "https://schema.org/FreeReturn"
{%- elsif booster_config.return_fees == 'customer_responsibility' -%}
            ,"returnFees": "https://schema.org/ReturnFeesCustomerResponsibility"
{%- elsif booster_config.return_fees == 'return_shipping_fees' -%}
            ,"returnFees": "https://schema.org/ReturnShippingFees"
{%- endif -%}
{%- if booster_config.return_method == 'by_mail' -%}
            ,"returnMethod": "https://schema.org/ReturnByMail"
{%- elsif booster_config.return_method == 'in_store' -%}
            ,"returnMethod": "https://schema.org/ReturnInStore"
{%- endif -%}
{%- if booster_config.refund_type == 'full_refund' -%}
            ,"refundType": "https://schema.org/FullRefund"
{%- elsif booster_config.refund_type == 'exchange_refund' -%}
            ,"refundType": "https://schema.org/ExchangeRefund"
{%- elsif booster_config.refund_type == 'store_credit_refund' -%}
            ,"refundType": "https://schema.org/StoreCreditRefund"
{%- endif -%}
          }
{%- endif -%}
{%- if ba_shipping_url != blank -%}
          ,"shippingDetails": {
            "@type": "OfferShippingDetails",
            "shippingSettingsLink": "{{ ba_shipping_url }}",
            "shippingDestination": {
              "@type": "DefinedRegion",
              "addressCountry": "{{ shop.address.country_code }}"
            }
{%- if booster_config.shipping_rate_value != blank -%}
            ,"shippingRate": {
              "@type": "MonetaryAmount",
              "value": "{{ booster_config.shipping_rate_value }}",
              "currency": "{{ shop.currency }}"
            }
{%- endif -%}
{%- if booster_config.handling_time_min != blank and booster_config.handling_time_max != blank or booster_config.transit_time_min != blank and booster_config.transit_time_max != blank -%}
            ,"deliveryTime": {
              "@type": "ShippingDeliveryTime"
{%- if booster_config.handling_time_min != blank and booster_config.handling_time_max != blank -%}
              ,"handlingTime": {
                "@type": "QuantitativeValue",
                "minValue": {{ booster_config.handling_time_min }},
                "maxValue": {{ booster_config.handling_time_max }},
                "unitCode": "DAY"
              }
{%- endif -%}
{%- if booster_config.transit_time_min != blank and booster_config.transit_time_max != blank -%}
              ,"transitTime": {
                "@type": "QuantitativeValue",
                "minValue": {{ booster_config.transit_time_min }},
                "maxValue": {{ booster_config.transit_time_max }},
                "unitCode": "DAY"
              }
{%- endif -%}
            }
{%- endif -%}
          }
{%- endif -%}
          ,"seller": {
            "@type": "Organization",
            "name": {{ shop.name | json }}
          }
}
        {%- if forloop.index < product.variants.size -%},{%- endif -%}
      {%- endfor -%}
    ]


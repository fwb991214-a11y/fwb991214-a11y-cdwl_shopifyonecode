{%- comment -%}
  "Use Shopify defaults" mode: when the merchant has selected this option for
  meta title or meta description, override whatever was assigned above with
  the [shopify_seo_title] / [shopify_seo_description] placeholders. The
  replacement step further down resolves these to Shopify's `page_title` and
  `page_description` Liquid variables, which mirror the merchant's native
  Shopify SEO fields. Single insertion point so all template types (product,
  collection, article, page, etc.) get consistent behavior, and so the
  storefront reflects the new mode immediately even before the next BatchScan.
{%- endcomment -%}
{%- if booster_config.auto_meta_title_active and booster_config.auto_meta_title_rules == 'shopify_seo_fields' -%}
  {%- assign booster_title = "[shopify_seo_title]" -%}
{%- endif -%}

{%- if booster_config.auto_meta_desc_active and booster_config.auto_meta_desc_rules == 'shopify_seo_fields' -%}
  {%- assign booster_desc = "[shopify_seo_description]" -%}
{%- endif -%}

{%- unless booster_title == blank -%}
  {%- assign booster_title = booster_title | replace : "[title]", [baType].title -%}
  {%- if baType == 'product' -%}
    {%- assign formatted_price = product.variants[0].price | money -%}
    {%- assign booster_title = booster_title | replace: "[price]", formatted_price -%}
    {%- assign booster_title = booster_title | replace : "[product_vendor]", [baType].vendor -%}
    {%- assign booster_title = booster_title | replace : "[product_type]", [baType].type -%}
  {%- endif -%}
  {%- assign booster_title = booster_title | replace : "[content]", [baType].content | strip_html -%}
  {%- assign booster_title = booster_title | replace : "[description]", [baType].description -%}
  {%- assign booster_title = booster_title | replace : "[shop_name]", shop.name -%}
  {%- assign booster_title = booster_title | replace : "[author]", [baType].author -%}
  {%- assign booster_title = booster_title | replace : "[shopify_seo_title]", page_title -%}
  <title>{{ booster_title | escape_once }}</title>
{%- else -%}
  <title>{{ page_title -}}
  {%- if current_tags -%} –
  {%- assign meta_tags = current_tags | join: ', ' -%}
  {%- assign translated_tags = 'general.meta.tags' | t: tags: meta_tags -%}
  {%- if translated_tags contains 'translation missing' -%} {{ meta_tags}}{%- else -%} {{ translated_tags }}{%- endif -%}
  {%- endif -%}
  {%- if current_page != 1 -%} –
  {%- assign translated_page = 'general.meta.page' | t: page: current_page -%}
  {%- if translated_page contains 'translation missing' or translated_page contains 'I18n Error' -%} {{ current_page }}{%- else -%} {{ translated_page }}{%- endif -%}
  {%- endif -%}
  </title>
{%- endunless -%}

{%- unless booster_config.google_verification_meta_tag == blank -%}
  {%- if booster_config.google_verification_meta_tag contains '<meta' -%}
    {{ booster_config.google_verification_meta_tag }}
  {%- else -%}
    <meta name="google-site-verification" content="{{ booster_config.google_verification_meta_tag }}" />
  {%- endif -%}
{%- endunless -%}

{%- unless booster_desc == blank -%}
  {%- assign formatted_price = product.variants[0].price | money -%}
  {%- assign booster_desc = booster_desc | replace : "[description]", [baType].description -%}
  {%- assign booster_desc = booster_desc | replace : "[price]", formatted_price -%}
  {%- assign booster_desc = booster_desc | replace : "[product_vendor]", [baType].vendor -%}
  {%- assign booster_desc = booster_desc | replace : "[product_type]", [baType].type -%}
  {%- assign booster_desc = booster_desc | replace : "[shop_name]", shop.name -%}
  {%- assign booster_desc = booster_desc | replace : "[title]", [baType].title -%}
  {%- assign booster_desc = booster_desc | replace : "[content]", [baType].content | strip_html -%}
  {%- assign booster_desc = booster_desc | replace : "[author]", [baType].author -%}
  {%- assign booster_desc = booster_desc | strip_html | truncate: 250  -%}
  {%- assign booster_desc = booster_desc | replace : "[shopify_seo_description]", page_description | strip | strip_newlines | escape_once -%}
  <meta name="description" content="{{ booster_desc | strip | strip_newlines | escape_once }}" />
{%- else -%}
  <meta name="description" content="{{ page_description | strip | strip_newlines | escape_once }}" />
{%- endunless -%}


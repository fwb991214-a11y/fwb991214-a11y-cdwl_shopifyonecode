      .ev-wholesale-page .our-contact h3 { font-size: 1.2rem; }

      .ev-wholesale-page .form-row { grid-template-columns: 1fr; }
      .ev-wholesale-page .staircase-text { font-size: 2rem; text-align: center; }
      .ev-wholesale-page h2 { font-size: 2rem; }
      .ev-wholesale-page section { padding: 60px 0; }

      .ev-wholesale-page .hero {
        height: 60vh;
        min-height: 500px;
        padding-left: 0;
        justify-content: center;
        text-align: center;
        align-items: center;
        display: flex;
      }

      .ev-wholesale-page .hero_img {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 100%;
        z-index: 1;
      }

      .ev-wholesale-page .hero_img img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }

      .ev-wholesale-page .hero-content {
        position: absolute;
        top: auto; left: auto;
        bottom: 20px;
        transform: none;
        align-items: center;
        padding: 0 20px;
        width: 100%;
       z-index: 2;
      }

      .ev-wholesale-page .cta-button {
        margin-top: 30px;
        padding: 14px 30px;
        font-size: 1rem;
        width: auto;
        max-width: 90%;
      }
    }

    /* Simple message styles */
    .ev-wholesale-page .form-notice {
      margin: 12px 0;
      padding: 10px 12px;
      border-radius: 6px;
      font-size: 0.95rem;
    }
    .ev-wholesale-page .form-notice.success {
      background: rgba(0, 128, 0, 0.08);
      border: 1px solid rgba(0, 128, 0, 0.25);
      color: #0b5;
    }
    .ev-wholesale-page .form-notice.error {
      background: rgba(255, 0, 0, 0.06);
      border: 1px solid rgba(255, 0, 0, 0.18);
      color: #c00;
    }

    /* Honeypot (anti-spam) */
    .ev-wholesale-page .hp-field {
      position: absolute !important;
      left: -9999px !important;
      top: -9999px !important;
      height: 0 !important;
      width: 0 !important;
      overflow: hidden !important;
    }



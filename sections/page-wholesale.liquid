<div class="ev-wholesale-page">
  <style>
    /* Scope EVERYTHING under .ev-wholesale-page to avoid affecting other pages */
    .ev-wholesale-page * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .ev-wholesale-page {
      color: #333;
      line-height: 1.6;
      background-color: #f5f5f5;
    }

    .ev-wholesale-page .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .ev-wholesale-page section {
      padding: 80px 0;
    }

    .ev-wholesale-page h2 {
      font-size: 2.5rem;
      margin-bottom: 50px;
      
      text-align: center;
      color: #000;
      position: relative;
    }

    /* Hero */
    .ev-wholesale-page .hero {
      padding: 0;
      width: 100%;
      position: relative;
      height: auto;
      background: #000;
    }

    .ev-wholesale-page .hero_img {
      width: 100%;
      height: auto;
      overflow: hidden;
    }

    .ev-wholesale-page .hero_img img {
      width: 100%;
      height: auto;
      display: block;
    }

    .ev-wholesale-page .hero-content {
      position: absolute;
      top: 12%;
      left: 10%;
    }

    .ev-wholesale-page .staircase-text {
      font-size: 6.5rem;
      font-weight: bold;
      margin-bottom: 30px;
      text-align: left;
      line-height: 1.2;
    }

    .ev-wholesale-page .staircase-text span {
      color: #fff;
      display: block;
    }

    .ev-wholesale-page .cta-button {
      display: inline-block;
      background: #132141;
      color: #fff;
      padding: 16px 48px;
      border-radius: 50px;
      text-decoration: none;
      font-size: 1.1rem;
      font-weight: 600;
      transition: all 0.4s cubic-bezier(0.23, 1, 0.32, 1);
      border: 1px solid #132141;
      margin-top: 30px;
      position: relative;
      overflow: hidden;
      z-index: 1;
      letter-spacing: 1px;
      text-transform: uppercase;
    }

    .ev-wholesale-page .cta-button:visited,
    .ev-wholesale-page .cta-button:active,
    .ev-wholesale-page .cta-button:focus {
      color: #fff;
      background: #132141;
    }

    .ev-wholesale-page .cta-button::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: #fff;
      z-index: -1;
      transition: transform 0.5s cubic-bezier(0.23, 1, 0.32, 1);
      transform: scaleX(0);
      transform-origin: right;
    }

    @media (hover: hover) {
      .ev-wholesale-page .cta-button:hover {
        color: #1a1a1a;
        border: 1px solid #132141;
        box-shadow: 0 15px 30px rgba(0,0,0,0.2);
        transform: translateY(-2px);
      }

      .ev-wholesale-page .cta-button:hover::before {
        transform: scaleX(1);
        transform-origin: left;
      }
    }

    /* Offerings */
    .ev-wholesale-page .offerings {
      background-color: #f0f0f0;
    }

    .ev-wholesale-page .offer-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 30px;
    }

    .ev-wholesale-page .offer-item {
      background-color: #fff;
      border-radius: 10px;
      overflow: hidden;
      box-shadow: 0 10px 20px rgba(0, 0, 0, 0.08);
      transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1), box-shadow 0.4s cubic-bezier(0.165, 0.84, 0.44, 1) !important;
    }

    .ev-wholesale-page .offer-item:hover {
      transform: translateY(-10px) !important;
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15) !important;
    }

    .ev-wholesale-page .offer-img {
      height: 200px;
      overflow: hidden;
    }

    .ev-wholesale-page .offer-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
      display: block;
    }

    .ev-wholesale-page .offer-item:hover .offer-img img {
      transform: scale(1.05);
    }

    .ev-wholesale-page .offer-content {
      padding: 25px;
    }

    .ev-wholesale-page .offer-content h3 {
      font-size: 1.5rem;
      margin-bottom: 15px;
      color: #000;
    }

    .ev-wholesale-page .offer-content p {
      color: #555;
    }

    /* Join Us */
    .ev-wholesale-page .join-us {
      background-color: #fff;
      padding: 0;
      padding-top:50px
    }

    .ev-wholesale-page .contact-container {
         display: flex;
    justify-content: center;
    width: 100%;
    }

    .ev-wholesale-page .contact-form h3,
    .ev-wholesale-page .our-contact h3 {
      font-size: 1.8rem;
      margin-bottom: 25px;
      color: #000;
    }

    .ev-wholesale-page .form-group {
      margin-bottom: 20px;
    }

    .ev-wholesale-page .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
    }

    .ev-wholesale-page .form-group input,
    .ev-wholesale-page .form-group select,
    .ev-wholesale-page .form-group textarea {
      width: 100%;
      padding: 12px 15px;
      border: 1px solid #ddd;
      border-radius: 5px;
      font-size: 1rem;
      color: #111;
      background: #fff;
    }

    .ev-wholesale-page .form-group input::placeholder,
    .ev-wholesale-page .form-group textarea::placeholder {
      color: #a9a9a9;
    }

    .ev-wholesale-page .form-group textarea {
      min-height: 120px;
      resize: vertical;
    }

    .ev-wholesale-page .form-row {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }

    .ev-wholesale-page .submit-btn {
      border: 2px solid transparent;
      background-color: #000;
      color: #fff;
      padding: 15px 30px;
      font-size: 1.1rem;
      border-radius: 5px;
      cursor: pointer;
      transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease;
      font-weight: bold;
      width: 100%;
    }

    .ev-wholesale-page .submit-btn:hover {
      background-color: #fff;
      border: 2px solid #000;
      color: #000;
    }

    .ev-wholesale-page .our-contact .contact-methods {
      display: flex;
          flex-wrap: wrap;
    }

    .ev-wholesale-page .contact-method {
      display: flex;
      align-items: center;
          width: 50%;
              margin-top: 20px;
    }

    .ev-wholesale-page .contact-method i {
      font-size: 1.5rem;
      color: #000;
      width: 30px;
    }

    /* Footer */
    .ev-wholesale-page .footer {
      background-color: #000;
      color: #fff;
      text-align: center;
      padding: 30px 0;
      margin-top: 50px;
    }

    /* Reveal animation */
    .ev-wholesale-page .reveal {
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.8s ease-out;
    }
    .ev-wholesale-page .reveal.active {
      opacity: 1;
      transform: translateY(0);
    }
    .ev-wholesale-page .delay-100 { transition-delay: 0.1s; }
    .ev-wholesale-page .delay-200 { transition-delay: 0.2s; }
    .ev-wholesale-page .delay-300 { transition-delay: 0.3s; }
    .ev-wholesale-page .delay-400 { transition-delay: 0.4s; }

    /* Focus */
    .ev-wholesale-page .form-group input:focus,
    .ev-wholesale-page .form-group select:focus,
    .ev-wholesale-page .form-group textarea:focus {
      border-color: #000;
      box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.1);
      outline: none;
      transition: all 0.3s ease;
    }

    /* Responsive */
    @media (max-width: 992px) {
      .ev-wholesale-page .offer-grid { grid-template-columns: 1fr; }
      .ev-wholesale-page .contact-container { grid-template-columns: 1fr; }
      .ev-wholesale-page .staircase-text { font-size: 2.5rem; }
    }

    @media (max-width: 768px) {

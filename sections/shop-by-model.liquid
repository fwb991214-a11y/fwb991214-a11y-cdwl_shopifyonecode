<section class="shop-by-model shop-by-model--{{ section.id }}">
  {% if section.settings.bg_image != blank %}
    <div class="shop-by-model__bg">
      <img
        src="{{ section.settings.bg_image | image_url: width: 2400 }}"
        alt="{{ section.settings.title | escape }}"
        loading="lazy"
        width="{{ section.settings.bg_image.width }}"
        height="{{ section.settings.bg_image.height }}"
      >
    </div>
  {% endif %}

  <div class="shop-by-model__overlay"></div>

  <div class="shop-by-model__inner">
    {% if section.settings.title != blank %}
      <h2 class="shop-by-model__title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="shop-by-model__grid">
      {% for block in section.blocks %}
        <div class="shop-by-model__item" {{ block.shopify_attributes }}>
          {% if block.settings.link != blank %}
            <a
              class="shop-by-model__item-link"
              href="{{ block.settings.link }}"
              {% if block.settings.open_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}
            >
          {% endif %}

          <div class="shop-by-model__image-box">
            {% if block.settings.image != blank %}
              <img
                class="shop-by-model__image"
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'shop-by-model__placeholder' }}
            {% endif %}
          </div>

          {% if block.settings.title != blank %}
            <div class="shop-by-model__name">{{ block.settings.title }}</div>
          {% endif %}

          {% if block.settings.link != blank %}
            </a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .shop-by-model--{{ section.id }} {
    position: relative;
    overflow: hidden;
    padding: 80px 0 80px;
    background: #0d2d2d;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: blur(2px);
    transform: scale(1.05);
  }

  .shop-by-model--{{ section.id }} .shop-by-model__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: rgba(6, 28, 33, 0.68);
  }

  .shop-by-model--{{ section.id }} .shop-by-model__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
    box-sizing: border-box;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__title {
    margin: 0 0 80px;
    text-align: center;
    color: #fff;
    font-size: 48px;
    line-height: 1.15;
    font-weight: 800;
    letter-spacing: 0;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: 68px 68px;
    align-items: start;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__item {
    text-align: center;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__item-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__image-box {
    position: relative;
    overflow: hidden;
   
    padding: 6px;
  
  }

  .shop-by-model--{{ section.id }} .shop-by-model__image {
    width: 100%;
    height: {{ section.settings.image_height }}px;
    object-fit: contain;
    display: block;
    transition: transform 0.35s ease;
    transform: scale(1);
    will-change: transform;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__item-link:hover .shop-by-model__image {
    transform: scale(1.08);
  }

  .shop-by-model--{{ section.id }} .shop-by-model__item-link:hover {
    transform: translateY(-2px);
  }

  .shop-by-model--{{ section.id }} .shop-by-model__name {
    margin-top: 14px;
    color: #fff;
    font-size: 20px;
    line-height: 1.25;
    font-weight: 600;
  }

  .shop-by-model--{{ section.id }} .shop-by-model__placeholder {
    width: 100%;
    height: {{ section.settings.image_height }}px;
    display: block;
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.25);
  }

  @media screen and (max-width: 989px) {
    .shop-by-model--{{ section.id }} {
      padding: 40px 0 48px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__title {
      font-size: 24px;
      margin-bottom: 50px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
      gap: 46px 46px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__name {
      font-size: 22px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__image,
    .shop-by-model--{{ section.id }} .shop-by-model__placeholder {
      height: {{ section.settings.image_height_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .shop-by-model--{{ section.id }} {
      padding: 28px 0 36px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__title {
      font-size: 24px;
      margin-bottom: 50px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__grid {
      grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
     gap: 46px 46px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__name {
      font-size: 16px;
      margin-top: 10px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__image-box {
      padding: 4px;
    }

    .shop-by-model--{{ section.id }} .shop-by-model__image,
    .shop-by-model--{{ section.id }} .shop-by-model__placeholder {
      height: {{ section.settings.image_height_mobile }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Shop by model",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "标题",
      "default": "Shop By Model"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "背景图"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "桌面端每行数量",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "平板每行数量",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "手机每行数量",
      "options": [
        {
          "value": "1",
          "label": "1列"
        },
        {
          "value": "2",
          "label": "2列"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "image_height",
      "label": "桌面端图片高度",
      "min": 80,
      "max": 260,
      "step": 10,
      "default": 120
    },
    {
      "type": "range",
      "id": "image_height_tablet",
      "label": "平板端图片高度",
      "min": 80,
      "max": 220,
      "step": 10,
      "default": 110
    },
    {
      "type": "range",
      "id": "image_height_mobile",
      "label": "手机端图片高度",
      "min": 60,
      "max": 180,
      "step": 10,
      "default": 90
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "车型卡片",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "图片"
        },
        {
          "type": "text",
          "id": "title",
          "label": "名称",
          "default": "2025+ Model Y"
        },
        {
          "type": "url",
          "id": "link",
          "label": "跳转链接"
        },
        {
          "type": "checkbox",
          "id": "open_new_tab",
          "label": "新窗口打开",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop by model",
      "blocks": [
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        },
        {
          "type": "item"
        }
      ]
    }
  ]
}
{% endschema %}
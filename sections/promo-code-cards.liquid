{%- if section.blocks.size > 0 -%}
  {%- render 'section-spacing-collapsing' -%}

  <style>
    #shopify-section-{{ section.id }} {
      --promo-codes-gap: {% if section.settings.gap == 'tight' %}var(--spacing-2){% elsif section.settings.gap == 'small' %}var(--spacing-4){% elsif section.settings.gap == 'large' %}var(--spacing-10){% else %}var(--spacing-6){% endif %};
      --promo-codes-columns-desktop: {{ section.settings.columns_desktop }};
    }

    /* Mobile: Swiper carousel */
    #shopify-section-{{ section.id }} .promo-codes__swiper {
      display: block;
          overflow: hidden;
    }

    #shopify-section-{{ section.id }} .promo-codes__swiper .swiper {
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .promo-codes__swiper .swiper-slide {
      height: auto;
    }

    #shopify-section-{{ section.id }} .promo-codes__swiper .swiper-pagination {
      position: static;
      margin-top: var(--spacing-6);
    }

    #shopify-section-{{ section.id }} .promo-codes__swiper .swiper-pagination-bullet {
      width: 10px;
      height: 10px;
      opacity: 0.35;
      background: rgb(var(--text-color));
    }

    #shopify-section-{{ section.id }} .promo-codes__swiper .swiper-pagination-bullet-active {
      opacity: 1;
    }

    #shopify-section-{{ section.id }} .promo-codes__card {
      overflow: hidden;
      display: grid;
      grid-template-rows: auto 1fr;
    }

    #shopify-section-{{ section.id }} .promo-codes__media {
      {% comment %} background: rgb(var(--text-color) / 0.04); {% endcomment %}
           {% comment %} border-radius:24px; {% endcomment %}
            overflow: hidden;
    }

    #shopify-section-{{ section.id }} .promo-codes__media img {
      width: 100%;
      height: auto;
      display: block;
    }

    #shopify-section-{{ section.id }} .promo-codes__content {
      padding: var(--spacing-6);
      display: grid;
      gap: var(--spacing-3);
      justify-items: center;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .promo-codes__code {
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    #shopify-section-{{ section.id }} .promo-codes__fineprint {
      color: rgb(var(--text-color) / 0.7);
      font-size: 0.875em;
      line-height: 1.4;
    }

    /* Desktop / tablet: grid layout */
    @media screen and (min-width: 700px) {
      #shopify-section-{{ section.id }} .promo-codes__swiper {
        display: none;
      }

      #shopify-section-{{ section.id }} .promo-codes__grid {
        display: grid;
        grid-template-columns: repeat(var(--promo-codes-columns-desktop), minmax(0, 1fr));
        gap: var(--promo-codes-gap);
      }
    }

    @media screen and (max-width: 999px) {
      /* keep */
    }

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .promo-codes__content {
        padding: var(--spacing-4);
      }
    }
  </style>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

  <div {% render 'section-properties' %}>
    <div class="section-stack">
      {%- render 'section-header',
        subheading: section.settings.subheading,
        heading: section.settings.heading,
        content: section.settings.content,
        text_alignment: 'center'
      -%}

      <div class="promo-codes__swiper sm:hidden" data-promo-codes-swiper>
        <div class="swiper" id="promo-codes-swiper-{{ section.id }}">
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              <div class="swiper-slide">
                <div class="promo-codes__card" {{ block.shopify_attributes }}>
                  <div class="promo-codes__media">
                    {%- if block.settings.image != blank -%}
                      {%- capture sizes -%}(max-width: 699px) calc(100vw - (var(--container-gutter) * 2)), (max-width: 999px) calc(50vw - (var(--container-gutter) * 2)), calc(min({{ settings.page_width }}px, 100vw) / {{ section.settings.columns_desktop }}){%- endcapture -%}
                      {{- block.settings.image
                        | image_url: width: block.settings.image.width
                        | image_tag: loading: 'lazy', sizes: sizes, widths: '360,540,720,900,1080,1440', class: 'promo-codes__image'
                      -}}
                    {%- else -%}
                      <div style="aspect-ratio: 4 / 5;"></div>
                    {%- endif -%}
                  </div>

                  <div class="promo-codes__content">
                    {%- if block.settings.title != blank -%}
                      <p class="h5">{{ block.settings.title | escape }}</p>
                    {%- endif -%}

                    {%- if block.settings.code != blank -%}
                      <p class="promo-codes__code">{{ block.settings.code | escape }}</p>
                    {%- endif -%}

                    {%- if block.settings.fineprint != blank -%}
                      <div class="promo-codes__fineprint">{{ block.settings.fineprint }}</div>
                    {%- endif -%}

                    {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
                      {%- render 'button',
                        content: block.settings.button_text,
                        href: block.settings.button_link,
                        size: 'lg'
                      -%}
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {%- endfor -%}
          </div>

          {%- if section.blocks.size > 1 -%}
            <div class="swiper-pagination" aria-hidden="true"></div>
          {%- endif -%}
        </div>
      </div>

      <div class="promo-codes__grid sm-max:hidden">
        {%- for block in section.blocks -%}
          <div class="promo-codes__card" {{ block.shopify_attributes }}>
            <div class="promo-codes__media">
              {%- if block.settings.image != blank -%}
                {%- capture sizes -%}(max-width: 699px) calc(100vw - (var(--container-gutter) * 2)), (max-width: 999px) calc(50vw - (var(--container-gutter) * 2)), calc(min({{ settings.page_width }}px, 100vw) / {{ section.settings.columns_desktop }}){%- endcapture -%}
                {{- block.settings.image
                  | image_url: width: block.settings.image.width
                  | image_tag: loading: 'lazy', sizes: sizes, widths: '360,540,720,900,1080,1440', class: 'promo-codes__image'
                -}}
              {%- else -%}
                <div style="aspect-ratio: 4 / 5;"></div>
              {%- endif -%}
            </div>

            <div class="promo-codes__content">
              {%- if block.settings.title != blank -%}
                <p class="h5">{{ block.settings.title | escape }}</p>
              {%- endif -%}

              {%- if block.settings.code != blank -%}
                <p class="promo-codes__code">{{ block.settings.code | escape }}</p>
              {%- endif -%}

              {%- if block.settings.fineprint != blank -%}
                <div class="promo-codes__fineprint">{{ block.settings.fineprint }}</div>
              {%- endif -%}

              {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
                {%- render 'button',
                  content: block.settings.button_text,
                  href: block.settings.button_link,
                  size: 'lg'
                -%}
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>

      <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>
      <script>
        (() => {
          const root = document.querySelector('#shopify-section-{{ section.id }} [data-promo-codes-swiper]');
          if (!root) return;

          const el = root.querySelector('.swiper');
          if (!el || el.dataset.initialized === 'true') return;
          el.dataset.initialized = 'true';

          const init = () => {
            if (!window.Swiper) return false;

            // eslint-disable-next-line no-new
            new window.Swiper(el, {
              slidesPerView: 1.05,
              spaceBetween: 12,
              centeredSlides: true,
              centeredSlidesBounds: true,
              watchOverflow: true,
              pagination: root.querySelector('.swiper-pagination')
                ? { el: root.querySelector('.swiper-pagination'), clickable: true }
                : undefined
            });

            return true;
          };

          if (!init()) {
            const t = setInterval(() => {
              if (init()) clearInterval(t);
            }, 50);
            setTimeout(() => clearInterval(t), 4000);
          }
        })();
      </script>
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Promo code cards",
  "class": "shopify-section--promo-code-cards",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "custom.overlay"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Limited-time offers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Save with promo codes"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "gap",
      "label": "Card gap",
      "options": [
        { "value": "tight", "label": "Tight" },
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns (desktop)",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "label": "Columns (tablet)",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "1"
    },
    {
      "type": "header",
      "content": "Colors",
      "info": "Uses section colors when set."
    },
    {
      "type": "color",
      "id": "background",
      "label": "Section background"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Section background gradient"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Code:"
        },
        {
          "type": "text",
          "id": "code",
          "label": "Promo code",
          "default": "SAVE10"
        },
        {
          "type": "richtext",
          "id": "fineprint",
          "label": "Fine print",
          "default": "<p>Valid on orders over $99. Cannot be combined with other discounts.</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Promo code cards",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}


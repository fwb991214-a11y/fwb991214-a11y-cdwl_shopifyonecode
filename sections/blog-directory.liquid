{% liquid
  assign columns_desktop = section.settings.columns_desktop
  assign show_article_count = section.settings.show_article_count
  assign show_latest_articles = section.settings.show_latest_articles
  assign article_limit = section.settings.article_limit
%}

<section
  id="shopify-section-{{ section.id }}"
  class="blog-directory section section--{{ section.id }}"
  style="
    --pt: {{ section.settings.padding_top }}px;
    --pb: {{ section.settings.padding_bottom }}px;
    --card-radius: {{ section.settings.card_radius }}px;
  "
>
  <div class="page-width">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="blog-directory__header">
        {% if section.settings.subheading != blank %}
          <p class="blog-directory__eyebrow">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="blog-directory__title">{{ section.settings.heading }}</h2>
        {% endif %}
      </div>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="blog-directory__grid blog-directory__grid--{{ columns_desktop }}">
        {% for block in section.blocks %}
          {% assign selected_blog = block.settings.blog %}

          {% if selected_blog != blank %}
            <article class="blog-directory__card" {{ block.shopify_attributes }}>
              {% if block.settings.image != blank %}
                <a class="blog-directory__image-link" href="{{ selected_blog.url }}">
                  {{
                    block.settings.image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '320, 480, 640, 900',
                      class: 'blog-directory__image',
                      alt: selected_blog.title
                  }}
                </a>
              {% endif %}

              <div class="blog-directory__content">
                <h3 class="blog-directory__card-title">
                  <a href="{{ selected_blog.url }}">
                    {{ block.settings.custom_title | default: selected_blog.title }}
                  </a>
                </h3>

                {% if block.settings.description != blank %}
                  <div class="blog-directory__desc rte">
                    {{ block.settings.description }}
                  </div>
                {% endif %}

                {% if show_article_count %}
                  <p class="blog-directory__meta">
                    {{ selected_blog.articles_count }} articles
                  </p>
                {% endif %}

                {% if show_latest_articles and selected_blog.articles_count > 0 %}
                  <ul class="blog-directory__articles">
                    {% for article in selected_blog.articles limit: article_limit %}
                      <li class="blog-directory__article-item">
                        <a href="{{ article.url }}">{{ article.title }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                {% endif %}

                <a class="blog-directory__button" href="{{ selected_blog.url }}">
                  {{ block.settings.button_label | default: '查看分类' }}
                </a>
              </div>
            </article>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="blog-directory__empty">
        <p>请在主题编辑器中添加博客分类。</p>
      </div>
    {% endif %}
  </div>
</section>

<style>
  .blog-directory {
    padding-top: var(--pt);
    padding-bottom: var(--pb);
  }

  .blog-directory .page-width {
    max-width: 1440px;
    margin: 0 auto;
    padding-left: 20px;
    padding-right: 20px;
  }

  .blog-directory__header {
    text-align: center;
    margin-bottom: 32px;
  }

  .blog-directory__eyebrow {
    margin: 0 0 8px;
    opacity: 0.7;
    font-size: 14px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .blog-directory__title {
    margin: 0;
    font-size: clamp(28px, 4vw, 44px);
    line-height: 1.15;
  }

  .blog-directory__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .blog-directory__grid--2 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .blog-directory__grid--3 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  .blog-directory__grid--4 {
    grid-template-columns: repeat(1, minmax(0, 1fr));
  }

  @media screen and (min-width: 750px) {
    .blog-directory__grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .blog-directory__grid--3 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .blog-directory__grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    .blog-directory__grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .blog-directory__grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .blog-directory__grid--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .blog-directory__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: var(--card-radius);
    background: rgb(var(--color-background, 255 255 255));
  }

  .blog-directory__image-link {
    display: block;
    overflow: hidden;
  }

  .blog-directory__image {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 10;
    object-fit: cover;
  }

  .blog-directory__content {
    padding: 20px;
  }

  .blog-directory__card-title {
    margin: 0 0 10px;
    font-size: 22px;
    line-height: 1.2;
  }

  .blog-directory__card-title a,
  .blog-directory__article-item a,
  .blog-directory__button {
    text-decoration: none;
  }

  .blog-directory__desc {
    margin-bottom: 12px;
    opacity: 0.8;
  }

  .blog-directory__meta {
    margin: 0 0 14px;
    font-size: 14px;
    opacity: 0.7;
  }

  .blog-directory__articles {
    margin: 0 0 18px;
    padding-left: 18px;
  }

  .blog-directory__article-item {
    margin-bottom: 8px;
  }

  .blog-directory__button {
    display: inline-block;
    margin-top: 6px;
    padding: 10px 18px;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 14px;
    line-height: 1;
  }

  .blog-directory__empty {
    text-align: center;
    padding: 32px 20px;
    border: 1px dashed rgba(0, 0, 0, 0.18);
    border-radius: 16px;
  }
</style>

{% schema %}
{
  "name": "Blog directory",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "副标题",
      "default": "Blog categories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "标题",
      "default": "Browse all blog categories"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "桌面端列数",
      "default": "3",
      "options": [
        { "value": "2", "label": "2列" },
        { "value": "3", "label": "3列" },
        { "value": "4", "label": "4列" }
      ]
    },
    {
      "type": "checkbox",
      "id": "show_article_count",
      "label": "显示文章数量",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_latest_articles",
      "label": "显示最新文章标题",
      "default": false
    },
    {
      "type": "range",
      "id": "article_limit",
      "label": "最新文章显示数量",
      "min": 1,
      "max": 6,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "卡片圆角",
      "min": 0,
      "max": 40,
      "step": 2,
      "default": 18
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "上边距",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "下边距",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "blog_item",
      "name": "Blog 分类",
      "settings": [
        {
          "type": "blog",
          "id": "blog",
          "label": "选择博客分类"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "封面图"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "自定义标题",
          "info": "留空则使用博客标题"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "描述"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "按钮文字",
          "default": "View categories"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blog directory",
      "blocks": [
        { "type": "blog_item" },
        { "type": "blog_item" },
        { "type": "blog_item" }
      ]
    }
  ]
}
{% endschema %}
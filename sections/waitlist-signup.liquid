<section class="waitlist-signup-section" id="waitlist-signup-{{ section.id }}">
  <div class="page-width">
    <div class="waitlist-signup__inner">
      {% if section.settings.heading != blank %}
        <h2 class="waitlist-signup__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      {% form 'customer', class: 'waitlist-signup__form' %}
        <input
          type="hidden"
          name="contact[tags]"
          value="waitlist{% if section.settings.source_tag != blank %},{{ section.settings.source_tag | handle }}{% endif %}"
        >

        {% if form.posted_successfully? %}
          <p class="waitlist-signup__success">
            Thanks! You've been added to the waitlist.
          </p>
        {% endif %}

        {% if form.errors %}
          <div class="waitlist-signup__error">
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="waitlist-signup__fields">
          <input
            class="waitlist-signup__input"
            type="email"
            name="contact[email]"
            id="WaitlistEmail-{{ section.id }}"
            value="{% if form.email %}{{ form.email }}{% endif %}"
            placeholder="{{ section.settings.placeholder }}"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            inputmode="email"
            required
          >

          <button
            type="submit"
            class="waitlist-signup__button"
          >
            {{ section.settings.button_label }}
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

<style>
  .waitlist-signup-section {
    padding: 48px 16px;
  }

  .waitlist-signup__inner {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .waitlist-signup__heading {
    margin: 0 0 20px;
    font-size: 32px;
    line-height: 1.2;
  }

  .waitlist-signup__form {
    margin-top: 12px;
  }

  .waitlist-signup__fields {
    display: flex;
    gap: 12px;
    align-items: stretch;
    justify-content: center;
    flex-wrap: nowrap;
  }

  .waitlist-signup__input {
    flex: 1 1 auto;
    width: 100%;
    min-width: 0;
    height: 52px;
    padding: 0 16px;
    border: 1px solid #d9d9d9;
    border-radius: 8px;
    font-size: 16px;
    outline: none;
    box-sizing: border-box;
    background: #fff;
    color: #111;
  }

  .waitlist-signup__input:focus {
    border-color: #111;
  }

  .waitlist-signup__button {
    flex: 0 0 auto;
    height: 52px;
    padding: 0 24px;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 16px;
    white-space: nowrap;
    background: #111;
    color: #fff;
  }

  .waitlist-signup__button:hover {
    opacity: 0.9;
  }

  .waitlist-signup__success {
    margin: 0 0 16px;
    color: #0a7a2f;
    font-size: 15px;
  }

  .waitlist-signup__error {
    margin: 0 0 16px;
    color: #c62828;
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .waitlist-signup-section {
      padding: 32px 16px;
    }

    .waitlist-signup__heading {
      margin-bottom: 16px;
      font-size: 26px;
    }

    .waitlist-signup__fields {
      flex-direction: column;
      gap: 10px;
    }

    .waitlist-signup__input,
    .waitlist-signup__button {
      width: 100%;
    }

    .waitlist-signup__button {
      padding: 0 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Waitlist signup",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join the Waitlist"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Notify Me"
    },
    {
      "type": "text",
      "id": "source_tag",
      "label": "Source tag",
      "default": "source-waitlist-page",
      "info": "用于后台区分表单来源，例如 source-home、source-product-footer"
    }
  ],
  "presets": [
    {
      "name": "Waitlist signup"
    }
  ]
}
{% endschema %}
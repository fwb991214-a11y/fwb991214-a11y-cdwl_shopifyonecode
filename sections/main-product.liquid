{%- render 'section-spacing-collapsing' -%}

<style>
/* shopify_product_tex2 商品描述（不含 iframe 视频尺寸） */

.product-desc {
  font-family: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial,
    "Noto Sans", "Microsoft YaHei", sans-serif;
  line-height: 1.6;
}

.product-desc section {
  margin: 28px 0;
}

.product-desc h2 {
  margin: 0 0 14px;
  line-height: 1.25;
  font-size: 1.5rem !important;
}

.product-desc h3 {
  margin: 14px 0 10px;
  line-height: 1.3;
  font-size: 1rem !important;
}

.product-desc p {
  margin: 10px 0;
}

.product-desc .pd-body {
  display: block;
}

.product-desc .pd-item {
  margin-top: 14px;
}

.product-desc .pd-media,
.product-desc .video-wrap {
  margin-top: 12px;
  display: grid;
  gap: 10px;
}

.product-desc img {
      width: 700px !important;
    max-width: 100% !important;
    height: auto !important;
    display: block !important;
}

/* Features：圆点 + 标题 + 正文同一行 */
.product-desc .feature-item {
  margin-top: 14px;
}

.product-desc .feature-line {
  margin: 10px 0;
 
  align-items: baseline;
  gap: 0.35em;
}

.product-desc .feature-bullet,
.product-desc .feature-title,
.product-desc .feature-text {
  display: inline;
  margin: 0;
}

.product-desc .feature-bullet {
  flex: 0 0 auto;
}

.product-desc .feature-title {
  flex: 0 0 auto;
  font-weight: 700;
}

.product-desc .feature-text {
  flex: 1 1 auto;
  min-width: 0;
  font-weight: 400;
}

.product-desc .feature-sub {
  margin: 10px 0 0;
}

/* FAQ（生成器输出为 ul/li） */
.product-desc .pd-faq ul {
  margin: 10px 0;
  padding-left: 1.2em;
}

.product-desc .pd-faq li {
  margin: 10px 0;
}

.product-desc .pd-faq li p {
  margin: 6px 0 0;
}

/* 旧版 FAQ 类名（若手写 faq-q / faq-a） */
.product-desc .pd-faq .faq-q {
  font-weight: 700;
  margin: 10px 0 6px;
  position: relative;
  padding-left: 1.2em;
}

.product-desc .pd-faq .faq-a {
  font-weight: 400;
  margin: 0 0 12px 1.2em;
}

.product-desc .pd-faq .faq-q::before {
  content: "•";
  position: absolute;
  left: 0;
  top: 0;
}

.product-desc .pd-faq .faq-a::before {
  content: "\00a0\00a0";
}


  #shopify-section-{{ section.id }} {
    --product-grid: auto / minmax(0, 1fr);
    --product-gallery-media-list-grid: auto / auto-flow {% if section.settings.mobile_carousel_control == 'free_scroll' %}{% if section.settings.mobile_media_size == 'expanded' %}84vw{% else %}73vw{% endif %}{% else %}100%{% endif %};
    --product-gallery-media-list-gap: {% if section.settings.mobile_media_size == 'expanded' %}var(--spacing-0-5){% else %}var(--grid-gutter){% endif %};
  }
   
    @media screen and (max-width: 1024px) {
 #shopify-section-{{ section.id }} .section {
      padding-block-end:24px
    }
    }


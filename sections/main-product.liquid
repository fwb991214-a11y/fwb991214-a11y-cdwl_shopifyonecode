{%- capture product_form_id -%}product-form-{{ product.id }}-{{ section.id }}{%- endcapture -%}

<div {% render 'section-properties', tight: true %}>
  <product-rerender id="product-info-{{ product.id }}-{{ section.id }}" observe-form="{{ product_form_id }}" allow-partial-rerender>
    <div class="product">
      {%- if product.media.size > 0 -%}
        {%- render 'product-gallery', product: product, product_form_id: product_form_id -%}
      {%- endif -%}

      <div class="product-info-column">
        <div class="product-info-panel">
          {%- render 'product-info',
            product: product,
            update_url: true,
            product_form_id: product_form_id,
            context: 'main_product'
          -%}
        </div>

        {%- assign pm_over_view = product.metafields.custom.pm_over_view.value -%}
        {%- if pm_over_view != blank -%}
          <div class="product-info-panel">
            <p class="product-pm-overview__title">Overview</p>

            <ul class="product-info__pm-overview-list" role="list" id="pm-product-overview-list-{{ section.id }}">
              {%- assign pm_over_view_lines = pm_over_view | newline_to_br | split: '<br />' -%}
              {%- for line in pm_over_view_lines -%}
                {%- assign cleaned = line | strip | remove_first: '•' | remove_first: '-' | strip -%}
                {%- if cleaned != blank -%}
                  <li>{{ cleaned }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>

            <script type="application/json" data-pm-product-overview-json="pm-product-overview-{{ section.id }}">
              {{- pm_over_view | strip | json -}}
            </script>

            <script>
              (() => {
                const key = "pm-product-overview-{{ section.id }}";
                const sc = document.querySelector(`script[type="application/json"][data-pm-product-overview-json="${key}"]`);
                const ul = document.getElementById("pm-product-overview-list-{{ section.id }}");
                if (!sc || !ul) return;

                const escapeHtml = (s) =>
                  String(s ?? '')
                    .replaceAll('&', '&amp;')
                    .replaceAll('<', '&lt;')
                    .replaceAll('>', '&gt;')
                    .replaceAll('"', '&quot;')
                    .replaceAll("'", '&#39;');

                const parseMaybeDoubleJson = (txt) => {
                  let data = JSON.parse(txt || 'null');
                  if (typeof data === 'string') data = JSON.parse(data);
                  return data;
                };

                let data;
                try {
                  data = parseMaybeDoubleJson(sc.textContent || '');
                } catch {
                  return; // keep Liquid-rendered fallback list
                }

                const items = Array.isArray(data?.overview) ? data.overview : null;
                if (!items) return; // keep fallback

                ul.innerHTML = items.map((t) => `<li>${escapeHtml(t)}</li>`).join('');
              })();
            </script>
          </div>

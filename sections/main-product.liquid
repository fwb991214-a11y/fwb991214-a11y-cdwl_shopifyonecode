        <script>
          (() => {
            const root = document.querySelector('#shopify-section-{{ section.id }} [data-anchor-tabs]');
            if (!root) return;

            const buttons = Array.from(root.querySelectorAll('[data-anchor]'));
            if (buttons.length === 0) return;

            const REVIEWS_SEL = '#pm-reviews-anchor-{{ section.id }}';

            const setCurrent = (btn) => {
              buttons.forEach((b) => b.setAttribute('aria-current', String(b === btn)));
            };

            const resolveTarget = (sel) => {
              let el = sel ? document.querySelector(sel) : null;
              if (!el && sel === REVIEWS_SEL) {
                el = document.getElementById('product-reviews')
                  || Array.from(document.querySelectorAll('.shopify-section--product-app-blocks .pm-app-blocks__title'))
                    .find((t) => (t.textContent || '').trim().toLowerCase() === 'reviews')
                    ?.closest('.shopify-section--product-app-blocks');
              }
              return el;
            };

            const buildPairs = () =>
              buttons
                .map((btn) => {
                  const sel = btn.getAttribute('data-anchor');
                  const el = resolveTarget(sel);
                  return el ? { btn, el } : null;
                })
                .filter(Boolean);

            /** Tab order can differ from DOM order — use vertical position on the page. */
            const sortPairsByPagePosition = (pairs) =>
              [...pairs].sort((a, b) => {
                const ya = a.el.getBoundingClientRect().top + window.scrollY;
                const yb = b.el.getBoundingClientRect().top + window.scrollY;
                return ya - yb;
              });

            /** Resolve theme sticky announcement + header offset for scrollspy line. */
            const readStickyOffsetPx = () => {
              const probe = document.createElement('div');
              probe.style.cssText =
                'position:absolute;left:0;width:1px;height:1px;margin:0;border:0;padding:0;visibility:hidden;pointer-events:none;top:0';
              probe.style.top = 'var(--sticky-area-height, 0px)';
              document.documentElement.appendChild(probe);
              const px = parseFloat(getComputedStyle(probe).top) || 0;
              probe.remove();
              return px;
            };

            let scrollLockUntil = 0;

            /**
             * Pick the tab that best matches what the user is viewing:
             * prefer the block with the largest overlap with the upper "reading zone" (below sticky chrome),
             * then fall back to classic anchor line (last section whose top crossed that line).
             */
            const syncActiveFromScroll = () => {
              if (Date.now() < scrollLockUntil) return;

              const pairs = buildPairs();
              if (pairs.length === 0) return;

              const sorted = sortPairsByPagePosition(pairs);
              const vh = window.innerHeight;
              const sticky = readStickyOffsetPx();
              const zoneTop = sticky;
              const zoneBottom = sticky + Math.min(vh * 0.48, Math.max(260, vh * 0.36));

              const scoreInZone = (r) => {
                if (r.height < 10) {
                  const mid = (r.top + r.bottom) / 2;
                  if (mid >= zoneTop && mid <= zoneBottom) return 1e6 + mid;
                  if (r.top < zoneBottom && r.bottom > zoneTop) return 5e5 + mid;
                  return -1;
                }
                const segTop = Math.max(r.top, zoneTop);
                const segBottom = Math.min(r.bottom, zoneBottom);
                return Math.max(0, segBottom - segTop);
              };

              let bestBtn = sorted[0].btn;
              let bestScore = -Infinity;

              for (const { btn, el } of sorted) {
                const sc = scoreInZone(el.getBoundingClientRect());
                if (sc > bestScore) {
                  bestScore = sc;
                  bestBtn = btn;
                }
              }

              if (!Number.isFinite(bestScore) || bestScore <= 0) {
                const line = sticky + Math.min(152, Math.max(80, vh * 0.19));
                bestBtn = sorted[0].btn;
                for (const { btn, el } of sorted) {
                  if (el.getBoundingClientRect().top <= line) bestBtn = btn;
                }
              }

              setCurrent(bestBtn);
            };

            let scrollRaf = 0;
            const scheduleSync = () => {
              cancelAnimationFrame(scrollRaf);
              scrollRaf = requestAnimationFrame(syncActiveFromScroll);
            };

            window.addEventListener('scroll', scheduleSync, { passive: true });
            window.addEventListener('resize', scheduleSync);

            if ('onscrollend' in window) {
              window.addEventListener(
                'scrollend',
                () => {
                  scrollLockUntil = 0;
                  syncActiveFromScroll();
                },
                { passive: true }
              );
            }

            if ('IntersectionObserver' in window) {
              const io = new IntersectionObserver(scheduleSync, {
                root: null,
                rootMargin: '-12% 0px -52% 0px',
                threshold: [0, 0.05, 0.12, 0.28, 0.45],
              });
              buildPairs().forEach(({ el }) => io.observe(el));
            }

            requestAnimationFrame(syncActiveFromScroll);

            buttons.forEach((btn) => {
              btn.addEventListener('click', () => {
                const sel = btn.getAttribute('data-anchor');
                const el = resolveTarget(sel);
                if (!el) return;

                setCurrent(btn);
                scrollLockUntil = Date.now() + 950;
                el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                window.setTimeout(() => {
                  scrollLockUntil = 0;
                  syncActiveFromScroll();
                }, 1000);
              });
            });
          })();
        </script>


            {%- assign pm_desc_6_content = product.metafields.custom.pm_desc_6_content.value | default: product.metafields.custom.pm_desc_6_content -%}

            {%- if pm_desc_6_image != blank or pm_desc_6_title != blank or pm_desc_6_content != blank -%}
              <div class="Overviews_content_item Overviews_content_item--rl">
                <div class="Overviews_content_item-text">
                  {%- if pm_desc_6_title != blank -%}
                    <div class="Overviews_content_item-title">{{ pm_desc_6_title }}</div>
                  {%- endif -%}

                  {%- if pm_desc_6_content != blank -%}
                    <div class="Overviews_content_item-content">
                      {{ pm_desc_6_content }}
                    </div>
                  {%- endif -%}
                </div>

                {%- if pm_desc_6_image != blank -%}
                  <div class="Overviews_content_item-media">
                    {{- pm_desc_6_image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '360,540,720,900,1200', sizes: '(min-width: 1000px) 50vw, 100vw' -}}
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

          </div>
          {%- endif -%}

          {%- if pm_more_info == blank and product.description != blank -%}
            <div id="pm-description-anchor-{{ section.id }}" class="pm-more-info pm-product-description">
              <div class="pm-more-info__header">
                <div class="pm-more-info__title">Description</div>
              </div>

              <div class="prose">
                {{- product.description -}}
              </div>
            </div>
          {%- endif -%}

          <!-- Product Videos -->
          {%- if has_videos -%}
            {%- assign pm_video_id = 'pm-videos-' | append: section.id -%}

            <div id="pm-videos-anchor-{{ section.id }}" class="fivestopsproduct_ProductVideos">
              <div class="pm-videos" id="{{ pm_video_id }}">
                <div class="pm-videos__title">Product Videos</div>

                <div class="pm-videos__tabs" role="tablist" aria-label="Product videos">
                  {%- if pm_desc_video_overview != blank -%}
                    <button class="pm-videos__tab" type="button" role="tab" aria-selected="true" data-target="overview">Product Overviews</button>
                  {%- endif -%}
                  {%- if pm_desc_video_review != blank -%}
                    <button class="pm-videos__tab" type="button" role="tab" aria-selected="{% if pm_desc_video_overview != blank %}false{% else %}true{% endif %}" data-target="review">Creator Reviews</button>
                  {%- endif -%}
                  {%- if pm_desc_video_installation != blank -%}
                    <button class="pm-videos__tab" type="button" role="tab" aria-selected="{% if pm_desc_video_overview != blank or pm_desc_video_review != blank %}false{% else %}true{% endif %}" data-target="installation">Installation Videos</button>
                  {%- endif -%}
                </div>

                <div class="pm-videos__panel" role="region" aria-live="polite">
                  {%- if pm_desc_video_overview != blank -%}
                    {%- assign v = pm_desc_video_overview | strip -%}
                    <div class="pm-videos__item" data-video="overview">
                      {%- if v contains '.mp4' or v contains '.webm' or v contains '.ogg' -%}
                        <video controls playsinline preload="metadata" src="{{ v | escape }}"></video>
                      {%- else -%}
                        <iframe src="{{ v | escape }}" title="Product overview video" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {%- if pm_desc_video_review != blank -%}
                    {%- assign v = pm_desc_video_review | strip -%}
                    <div class="pm-videos__item" data-video="review" {% if pm_desc_video_overview != blank %}hidden{% endif %}>
                      {%- if v contains '.mp4' or v contains '.webm' or v contains '.ogg' -%}
                        <video controls playsinline preload="metadata" src="{{ v | escape }}"></video>
                      {%- else -%}
                        <iframe src="{{ v | escape }}" title="Creator review video" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      {%- endif -%}
                    </div>
                  {%- endif -%}

                  {%- if pm_desc_video_installation != blank -%}
                    {%- assign v = pm_desc_video_installation | strip -%}
                    <div class="pm-videos__item" data-video="installation" {% if pm_desc_video_overview != blank or pm_desc_video_review != blank %}hidden{% endif %}>
                      {%- if v contains '.mp4' or v contains '.webm' or v contains '.ogg' -%}
                        <video controls playsinline preload="metadata" src="{{ v | escape }}"></video>
                      {%- else -%}
                        <iframe src="{{ v | escape }}" title="Installation video" loading="lazy" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
                      {%- endif -%}
                    </div>
                  {%- endif -%}
                </div>
              </div>

              <script>
                (() => {
                  const root = document.getElementById({{ pm_video_id | json }});
                  if (!root) return;

                  const tabs = Array.from(root.querySelectorAll('[role="tab"][data-target]'));
                  const items = Array.from(root.querySelectorAll('.pm-videos__item[data-video]'));
                  if (tabs.length === 0 || items.length === 0) return;

                  const normalizeYoutubeEmbedUrl = (raw) => {
                    const s = String(raw ?? '').trim();
                    if (!s) return s;
                    if (!/^https?:\/\//i.test(s)) return s;

                    let url;
                    try {
                      url = new URL(s);
                    } catch {
                      return s;
                    }

                    const host = url.hostname.replace(/^www\./i, '').toLowerCase();
                    const path = url.pathname || '/';

                    // Already an embed URL.
                    if (host.includes('youtube') && path.startsWith('/embed/')) return url.toString();

                    // youtu.be/<id>
                    if (host === 'youtu.be') {
                      const id = path.split('/').filter(Boolean)[0];
                      if (!id) return s;
                      return `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}`;
                    }

                    // youtube.com/watch?v=<id>
                    if (host.includes('youtube') && path === '/watch') {
                      const id = url.searchParams.get('v');
                      if (!id) return s;
                      return `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}`;
                    }

                    // youtube.com/shorts/<id>
                    if (host.includes('youtube') && path.startsWith('/shorts/')) {
                      const id = path.split('/').filter(Boolean)[1];
                      if (!id) return s;
                      return `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}`;
                    }

                    return s;
                  };

                  // Fix common YouTube URLs that can't be framed (watch/shorts/youtu.be) by converting to /embed/.
                  items.forEach((it) => {
                    const iframe = it.querySelector('iframe');
                    if (!iframe) return;
                    const src = iframe.getAttribute('src') || '';
                    const normalized = normalizeYoutubeEmbedUrl(src);
                    if (normalized && normalized !== src) {
                      iframe.setAttribute('src', normalized);
                    }
                  });

                  const setActive = (key) => {
                    tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.target === key)));
                    items.forEach((it) => {
                      const active = it.dataset.video === key;
                      it.toggleAttribute('hidden', !active);

                      if (!active) {
                        const v = it.querySelector('video');
                        if (v) v.pause();
                      }
                    });
                  };

                  const initial = tabs.find((t) => t.getAttribute('aria-selected') === 'true')?.dataset.target || tabs[0].dataset.target;
                  setActive(initial);

                  tabs.forEach((tab) => {
                    tab.addEventListener('click', () => setActive(tab.dataset.target));
                  });
                })();
              </script>
            </div>
          {%- endif -%}

          <!-- MoreInfo -->
          <div id="pm-more-info-anchor-{{ section.id }}" class="fivestopsproduct_MoreInfo">
            {%- if pm_more_info != blank -%}
              {%- assign pm_more_info_id = 'pm-more-info-' | append: section.id -%}

              <div class="pm-more-info" id="{{ pm_more_info_id }}">
                <div class="pm-more-info__header">
                  <div class="pm-more-info__title">More Info</div>
                  <button class="pm-more-info__toggle" type="button" aria-expanded="true" aria-controls="{{ pm_more_info_id }}-content"></button>
                </div>

                <div class="pm-more-info__content-wrap">
                  <div class="pm-more-info__content" id="{{ pm_more_info_id }}-content"></div>
                </div>
              </div>

              <script type="application/json" data-pm-more-info-json="{{ pm_more_info_id }}">
                {{- pm_more_info | strip | json -}}
              </script>

              <script>
                (() => {
                  const rootId = {{ pm_more_info_id | json }};
                  const root = document.getElementById(rootId);
                  if (!root) return;

                  const jsonScript = document.querySelector(`script[type="application/json"][data-pm-more-info-json="${rootId}"]`);
                  if (!jsonScript) return;

                  const container = root.querySelector('.pm-more-info__content');
                  if (!container) return;

                  const toggleBtn = root.querySelector('.pm-more-info__toggle');
                  const contentWrap = root.querySelector('.pm-more-info__content-wrap');

                  const syncHeight = () => {
                    if (!contentWrap) return;
                    if (root.classList.contains('is-collapsed')) {
                      contentWrap.style.maxHeight = '0px';
                    } else {
                      contentWrap.style.maxHeight = `${contentWrap.scrollHeight}px`;
                    }
                  };

                  const escapeHtml = (s) =>
                    String(s ?? '')
                      .replaceAll('&', '&amp;')
                      .replaceAll('<', '&lt;')
                      .replaceAll('>', '&gt;')
                      .replaceAll('"', '&quot;')
                      .replaceAll("'", '&#39;');

                  const renderTable = (rows) => {
                    const body = rows
                      .map(([k, v]) => `<tr><th scope="row">${escapeHtml(k)}</th><td>${escapeHtml(v)}</td></tr>`)
                      .join('');
                    return `<table class="pm-more-info__table"><tbody>${body}</tbody></table>`;
                  };

                  let data;
                  try {
                    data = JSON.parse(jsonScript.textContent || 'null');

                    // The metafield content is itself JSON, but we serialize it via Liquid `json`,
                    // so the first parse may yield a string. In that case, parse one more time.
                    if (typeof data === 'string') {
                      data = JSON.parse(data);
                    }
                  } catch (e) {
                    container.innerHTML = `<div class="prose"><pre>${escapeHtml(jsonScript.textContent)}</pre></div>`;
                    return;
                  }

                  const specs = Array.isArray(data?.specifications) ? data.specifications : [];
                  const packages = Array.isArray(data?.package_includes) ? data.package_includes : [];

                  if (specs.length === 0 && packages.length === 0) {
                    container.innerHTML = `<div class="prose"><pre>${escapeHtml(jsonScript.textContent)}</pre></div>`;
                    return;
                  }

                  const pkgRows = packages.map((p, idx) => [`List${idx + 1}`, p]);
                  const isMobile = () => window.matchMedia && window.matchMedia('(max-width: 999px)').matches;

                  const renderSpecsTable = (rows, mobile) => {
                    const body = [];
                    if (mobile) {
                      for (let i = 0; i < rows.length; i += 1) {
                        const a = rows[i];
                        body.push(
                          `<tr>
                            <th scope="row">${escapeHtml(a?.[0] ?? '')}</th>
                            <td>${escapeHtml(a?.[1] ?? '')}</td>
                          </tr>`
                        );
                      }
                    } else {
                      for (let i = 0; i < rows.length; i += 2) {
                        const a = rows[i];
                        const b = rows[i + 1];
                        body.push(
                          `<tr>
                            <th scope="row">${escapeHtml(a?.[0] ?? '')}</th>
                            <td>${escapeHtml(a?.[1] ?? '')}</td>
                            <th scope="row">${escapeHtml(b?.[0] ?? '')}</th>
                            <td>${escapeHtml(b?.[1] ?? '')}</td>
                          </tr>`
                        );
                      }
                    }

                    return `<table class="pm-more-info__table pm-more-info__table--spec"><tbody>${body.join('')}</tbody></table>`;
                  };

                  const renderPackageTable = (rows, mobile) => {
                    const body = [];
                    if (mobile) {
                      for (let i = 0; i < rows.length; i += 1) {
                        const a = rows[i];
                        body.push(
                          `<tr>
                            <th scope="row">${escapeHtml(a?.[0] ?? '')}</th>
                            <td>${escapeHtml(a?.[1] ?? '')}</td>
                          </tr>`
                        );
                      }
                    } else {
                      for (let i = 0; i < rows.length; i += 2) {
                        const a = rows[i];
                        const b = rows[i + 1];

                        body.push(
                          `<tr>
                            <th scope="row">${escapeHtml(a?.[0] ?? '')}</th>
                            <td>${escapeHtml(a?.[1] ?? '')}</td>
                            <th scope="row">${escapeHtml(b?.[0] ?? '')}</th>
                            <td>${escapeHtml(b?.[1] ?? '')}</td>
                          </tr>`
                        );
                      }
                    }

                    return `<table class="pm-more-info__table pm-more-info__table--pkg"><tbody>${body.join('')}</tbody></table>`;
                  };

                  const renderAll = () => {
                    const specRows = specs.map((s) => [s?.label, s?.value]);
                    const specsHtml = specs.length
                      ? `
                        <div class="pm-more-info__section-title">Specification(${specs.length})</div>
                        <div class="pm-more-info__grid">
                          ${renderSpecsTable(specRows, isMobile())}
                        </div>
                      `
                      : '';

                    const pkgHtml = packages.length
                      ? `
                        <div class="pm-more-info__section-title">Package Includes(${packages.length})</div>
                        <div class="pm-more-info__grid">
                          ${renderPackageTable(pkgRows, isMobile())}
                        </div>
                      `
                      : '';

                    container.innerHTML = `${specsHtml}${pkgHtml}`;
                  };

                  renderAll();

                  // After rendering tables, sync expanded height.
                  syncHeight();

                  // Re-render package table on breakpoint changes and sync height.
                  let lastMobile = isMobile();
                  window.addEventListener(
                    'resize',
                    () => {
                      const nowMobile = isMobile();
                      if (nowMobile !== lastMobile) {
                        lastMobile = nowMobile;
                        renderAll();
                      }
                      syncHeight();
                    },
                    { passive: true }
                  );

                  if (toggleBtn) {
                    toggleBtn.addEventListener('click', () => {
                      const collapsed = root.classList.toggle('is-collapsed');
                      toggleBtn.setAttribute('aria-expanded', String(!collapsed));
                      syncHeight();
                    });
                  }
                })();
              </script>
            {%- endif -%}
          </div>

          <!-- faq -->
          <div id="pm-faq-anchor-{{ section.id }}" class="fivestopsproduct_Faq">
            {%- assign pm_faq = product.metafields.custom.pm_faq.value | default: product.metafields.custom.pm_faq -%}
            {%- if pm_faq != blank -%}
              {%- assign pm_faq_id = 'pm-faq-' | append: section.id -%}

              <div class="pm-faq is-collapsed" id="{{ pm_faq_id }}">
                <div class="pm-faq__header">
                  <div class="pm-faq__title">FAQ</div>
                  <button class="pm-faq__toggle" type="button" aria-expanded="false" aria-controls="{{ pm_faq_id }}-content"></button>
                </div>

                <div class="pm-faq__content-wrap">
                  <div class="pm-faq__content" id="{{ pm_faq_id }}-content"></div>
                </div>
              </div>

              <script type="application/json" data-pm-faq-json="{{ pm_faq_id }}">
                {{- pm_faq | strip | json -}}
              </script>

              <script>
                (() => {
                  const rootId = {{ pm_faq_id | json }};
                  const root = document.getElementById(rootId);
                  if (!root) return;

                  const jsonScript = document.querySelector(`script[type="application/json"][data-pm-faq-json="${rootId}"]`);
                  if (!jsonScript) return;

                  const container = root.querySelector('.pm-faq__content');
                  if (!container) return;

                  const toggleBtn = root.querySelector('.pm-faq__toggle');
                  const contentWrap = root.querySelector('.pm-faq__content-wrap');

                  const syncHeight = () => {
                    if (!contentWrap) return;
                    if (root.classList.contains('is-collapsed')) {
                      contentWrap.style.maxHeight = '0px';
                    } else {
                      contentWrap.style.maxHeight = `${contentWrap.scrollHeight}px`;
                    }
                  };

                  const escapeHtml = (s) =>
                    String(s ?? '')
                      .replaceAll('&', '&amp;')
                      .replaceAll('<', '&lt;')
                      .replaceAll('>', '&gt;')
                      .replaceAll('"', '&quot;')
                      .replaceAll("'", '&#39;');

                  let data;
                  try {
                    data = JSON.parse(jsonScript.textContent || 'null');
                    if (typeof data === 'string') data = JSON.parse(data);
                  } catch (e) {
                    container.innerHTML = `<div class="prose"><pre>${escapeHtml(jsonScript.textContent)}</pre></div>`;
                    return;
                  }

                  const items = Array.isArray(data?.faq) ? data.faq : [];
                  if (items.length === 0) return;

                  const listHtml = items
                    .map((it, idx) => {
                      const q = it?.question ?? '';
                      const a = it?.answer ?? '';
                      return `
                        <div class="pm-faq__item" data-idx="${idx}">
                          <div class="pm-faq__a-wrap">
                            <div class="pm-faq__q-text">${escapeHtml(q)}</div>
                            <div class="pm-faq__a">${escapeHtml(a)}</div>
                          </div>
                        </div>
                      `;
                    })
                    .join('');

                  container.innerHTML = `<div class="pm-faq__list">${listHtml}</div>`;

                  // After rendering, sync the whole FAQ height
                  syncHeight();

                  window.addEventListener(
                    'resize',
                    () => {
                      syncHeight();
                    },
                    { passive: true }
                  );

                  if (toggleBtn) {
                    toggleBtn.addEventListener('click', () => {
                      const collapsed = root.classList.toggle('is-collapsed');
                      toggleBtn.setAttribute('aria-expanded', String(!collapsed));
                      syncHeight();
                    });
                  }
                })();
              </script>
            {%- endif -%}
          </div>

          <!-- Reviews -->
          <div id="pm-reviews-anchor-{{ section.id }}" class="fivestopsproduct_Reviews"></div>
        </div>
      </div>
    </div>
  </product-rerender>
</div>

{%- assign buy_buttons_block = section.blocks | where: 'type', 'buy_buttons' | first -%}

{%- if section.settings.show_fixed_add_to_cart and product.available and buy_buttons_block != blank -%}
  <product-rerender id="{{ product_form_id }}-sticky-bar" observe-form="{{ product_form_id }}">
    {%- if product.selected_or_first_available_variant.available -%}
      <product-quick-add form="{{ product_form_id }}" class="product-quick-add">
        {%- assign button_label = 'product.general.add_to_cart_button' | t -%}

        <buy-buttons template="{{ product.template_suffix }}" form="{{ product_form_id }}" class="sm:hidden">
          {%- render 'button', type: 'submit', content: button_label, form: product_form_id, background: buy_buttons_block.settings.atc_button_background, text_color: buy_buttons_block.settings.atc_button_text_color, secondary: true, stretch: true, size: 'lg' -%}
        </buy-buttons>

        {%- assign image = product.selected_or_first_available_variant.featured_media | default: product.featured_media -%}

        <div class="product-quick-add__variant {% if image == blank %}no-image{% endif %} hidden sm:grid">
          {%- if image != blank -%}
            <variant-media widths="80,160" form="{{ product_form_id }}">
              {{- image | image_url: width: image.width | image_tag: loading: 'lazy', sizes: '80px', widths: '80,160', class: 'rounded-xs' -}}
            </variant-media>
          {%- endif -%}

          <div class="v-stack gap-0.5">
            {%- assign vendor_block = section.blocks | where: 'type', 'vendor' -%}

            {%- if vendor_block != blank -%}
              {%- render 'vendor' with product.vendor, class: 'text-xs' -%}
            {%- endif -%}

            <a href="{{ product.url }}" class="bold truncate-text">{{ product.title }}</a>
            {%- render 'price-list', product: product, variant: product.selected_or_first_available_variant, form_id: product_form_id -%}
          </div>

          <buy-buttons template="{{ product.template_suffix }}" form="{{ product_form_id }}" force-secondary-button>
            {%- render 'button', type: 'submit', content: button_label, form: product_form_id, background: buy_buttons_block.settings.atc_button_background, text_color: buy_buttons_block.settings.atc_button_text_color, secondary: true -%}
          </buy-buttons>
        </div>
      </product-quick-add>
    {%- endif -%}
  </product-rerender>
{%- endif -%}

{%- comment -%}
IMPLEMENTATION NOTE: Shopify does not currently allows to render a given section within the context of a given product. However,
when rendering the quick buy popovers, we want to be able to re-use the merchant's choices (such as the selector type). This
is however only possible by rendering the whole product page, and extracting the relevant part. Here, we therefore render the
quick buy information in a template, that will be extracted in JS, but ensure it is not visible in the main product page
{%- endcomment -%}

{%- render 'product-quick-buy', product: product -%}


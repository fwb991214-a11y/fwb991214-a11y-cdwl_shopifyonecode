{%- render 'section-spacing-collapsing' -%}

{%- liquid
  assign desktop_image = section.settings.image
  assign mobile_image = section.settings.mobile_image | default: desktop_image
  assign show_banner = false

  if desktop_image != blank or mobile_image != blank
    assign show_banner = true
  endif
-%}

{%- if show_banner -%}
  <style>
    #shopify-section-{{ section.id }} .section {
      --section-outer-spacing-block: 0;
      --section-spacing-block: 0;
      --section-spacing-block-start: 0;
      --section-spacing-block-end: 0;
      padding-block: 0 !important;
    }

    #shopify-section-{{ section.id }} .promo-image-banner__link {
      display: block;
      text-decoration: none;
      color: inherit;
    }

    #shopify-section-{{ section.id }} .promo-image-banner__picture {
      display: block;
      line-height: 0;
    }

    #shopify-section-{{ section.id }} .promo-image-banner__image {
      width: 100%;
      height: auto;
      display: block;
    }

    {%- unless section.settings.full_width -%}
      #shopify-section-{{ section.id }} .promo-image-banner--boxed {
        border-radius: var(--rounded-lg);
        overflow: hidden;
        box-shadow: var(--shadow-block);
      }
    {%- endunless -%}
  </style>

  <div {% render 'section-properties', tight: true %}>
    <div class="promo-image-banner{% if section.settings.full_width %} full-bleed{% else %} container promo-image-banner--boxed{% endif %}">
      {%- capture banner_image -%}
        <picture class="promo-image-banner__picture">
          {%- if section.settings.mobile_image != blank -%}
            <source
              media="(max-width: 699px)"
              srcset="{{ section.settings.mobile_image | image_url: width: 400 }} 400w, {{ section.settings.mobile_image | image_url: width: 600 }} 600w, {{ section.settings.mobile_image | image_url: width: 800 }} 800w, {{ section.settings.mobile_image | image_url: width: 1000 }} 1000w, {{ section.settings.mobile_image | image_url: width: 1200 }} 1200w"
              width="{{ section.settings.mobile_image.width }}"
              height="{{ section.settings.mobile_image.height }}"
            >
          {%- endif -%}

          {%- assign render_image = desktop_image | default: mobile_image -%}
          {%- capture sizes -%}{% if section.settings.full_width %}100vw{% else %}(max-width: 740px) calc(100vw - 40px), (max-width: 999px) calc(100vw - 64px), min({{ settings.page_width }}px, 100vw - 96px){% endif %}{%- endcapture -%}
          {%- assign image_alt = section.settings.image_alt | default: render_image.alt | escape -%}

          {{- render_image | image_url: width: render_image.width | image_tag: loading: 'eager', fetchpriority: 'high', class: 'promo-image-banner__image', sizes: sizes, widths: '400,600,800,1000,1200,1400,1600,1800,2000,2400,2800,3200', alt: image_alt -}}
        </picture>
      {%- endcapture -%}

      {%- if section.settings.link != blank -%}
        <a
          href="{{ section.settings.link }}"
          class="promo-image-banner__link"
          {% if section.settings.open_in_new_tab %}
            target="_blank"
            rel="noopener noreferrer"
          {% endif %}
        >
          {{- banner_image -}}
        </a>
      {%- else -%}
        {{- banner_image -}}
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Promo image banner",
  "class": "shopify-section--promo-image-banner",
  "tag": "section",
  "enabled_on": {
    "templates": ["collection", "product"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image",
      "info": "Optional. Uses desktop image when empty."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Optional. Uses image alt from the file when empty."
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "checkbox",
      "id": "open_in_new_tab",
      "label": "Open link in new tab",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Promo image banner"
    }
  ]
}
{% endschema %}

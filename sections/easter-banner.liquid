{% if section.settings.image != blank or section.settings.mobile_image != blank %}
  <section class="easter-banner-section" id="easter-banner-{{ section.id }}">
    {% if section.settings.link != blank %}
      <a href="{{ section.settings.link }}" class="easter-banner-link">
    {% endif %}

    <div class="easter-banner">
      <picture>
        {% if section.settings.mobile_image != blank %}
          <source
            media="(max-width: 749px)"
            srcset="
              {{ section.settings.mobile_image | image_url: width: 375 }} 375w,
              {{ section.settings.mobile_image | image_url: width: 550 }} 550w,
              {{ section.settings.mobile_image | image_url: width: 750 }} 750w,
              {{ section.settings.mobile_image | image_url: width: 900 }} 900w
            "
            sizes="100vw"
          >
        {% endif %}

        {% if section.settings.image != blank %}
          <img
            class="easter-banner__img"
            src="{{ section.settings.image | image_url: width: 2400 }}"
            srcset="
              {{ section.settings.image | image_url: width: 750 }} 750w,
              {{ section.settings.image | image_url: width: 1100 }} 1100w,
              {{ section.settings.image | image_url: width: 1500 }} 1500w,
              {{ section.settings.image | image_url: width: 2000 }} 2000w,
              {{ section.settings.image | image_url: width: 2400 }} 2400w
            "
            sizes="100vw"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        {% elsif section.settings.mobile_image != blank %}
          <img
            class="easter-banner__img"
            src="{{ section.settings.mobile_image | image_url: width: 900 }}"
            srcset="
              {{ section.settings.mobile_image | image_url: width: 375 }} 375w,
              {{ section.settings.mobile_image | image_url: width: 550 }} 550w,
              {{ section.settings.mobile_image | image_url: width: 750 }} 750w,
              {{ section.settings.mobile_image | image_url: width: 900 }} 900w
            "
            sizes="100vw"
            alt="{{ section.settings.mobile_image.alt | escape }}"
            width="{{ section.settings.mobile_image.width }}"
            height="{{ section.settings.mobile_image.height }}"
            loading="lazy"
          >
        {% endif %}
      </picture>
    </div>

    {% if section.settings.link != blank %}
      </a>
    {% endif %}
  </section>
{% endif %}

<style>
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
  }

  #easter-banner-{{ section.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    padding: 0;
    line-height: 0;
    overflow: hidden;
  }

  #easter-banner-{{ section.id }} .easter-banner-link {
    display: block;
    text-decoration: none;
  }

  #easter-banner-{{ section.id }} .easter-banner {
    width: 100%;
  }

  #easter-banner-{{ section.id }} .easter-banner__img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 749px) {
    #easter-banner-{{ section.id }} {
      width: 100vw;
      max-width: 100vw;
      margin-left: calc(50% - 50vw);
      margin-right: calc(50% - 50vw);
    }
  }
</style>

{% schema %}
{
  "name": "Easter Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner link"
    }
  ],
  "presets": [
    {
      "name": "Easter Banner"
    }
  ]
}
{% endschema %}
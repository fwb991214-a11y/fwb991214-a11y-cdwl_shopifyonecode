{%- render 'section-spacing-collapsing' -%}

{%- liquid
  assign model_blocks = section.blocks | where: 'type', 'model_item'
  assign group_blocks = section.blocks | where: 'type', 'product_group'
  assign has_groups = false

  for block in group_blocks
    if block.settings.title != blank and block.settings.collection != blank
      assign has_groups = true
      break
    endif
  endfor
-%}

<style>
  #shopify-section-{{ section.id }} {
    --product-list-gap: {% if section.settings.products_per_row_mobile == '2' %}var(--product-list-row-gap) var(--spacing-1){% else %}var(--product-list-row-gap) var(--product-list-column-gap){% endif %};
    --product-list-items-per-row: {{ section.settings.products_per_row_mobile | times: 1 }};
    --product-list-grid: auto-flow dense / repeat(var(--product-list-items-per-row), minmax(0, 1fr));
  }

  @media screen and (min-width: 700px) {
    #shopify-section-{{ section.id }} {
      --product-list-gap: var(--product-list-row-gap) var(--product-list-column-gap);
      --product-list-items-per-row: 2;
    }
  }

  @media screen and (min-width: 1000px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {{ section.settings.products_per_row_desktop | at_most: 3 }};
    }
  }

  @media screen and (min-width: 1200px) {
    #shopify-section-{{ section.id }} {
      --product-list-items-per-row: {{ section.settings.products_per_row_desktop }};
    }
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model {
    margin-bottom: var(--spacing-10);
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__heading {
    margin: 0 0 var(--spacing-6);
    text-align: center;
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.model_columns_desktop }}, minmax(0, 1fr));
    gap: var(--spacing-6) var(--spacing-4);
    max-width: 1100px;
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__item {
    display: grid;
    gap: var(--spacing-3);
    justify-items: center;
    text-align: center;
    text-decoration: none;
    color: inherit;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__image-wrap {
    width: 100%;
    aspect-ratio: 1.35;
    display: grid;
    place-items: center;
    min-width: 0;
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ section.id }} .page-bundle-shop-by-model__label {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.3;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .page-bundle-shop-by-model__heading {
      font-size: 1.5rem;
      margin-bottom: var(--spacing-4);
    }

    #shopify-section-{{ section.id }} .page-bundle-shop-by-model__grid {
      grid-template-columns: repeat({{ section.settings.model_columns_mobile }}, minmax(0, 1fr));
      gap: var(--spacing-4) var(--spacing-2);
    }

    #shopify-section-{{ section.id }} .page-bundle-shop-by-model__label {
      font-size: 0.875rem;
    }
  }

  #shopify-section-{{ section.id }} .subcollection-load-more__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--spacing-6);
    margin-bottom: 0;
  }

  #shopify-section-{{ section.id }} .subcollection-load-more__footer:has([data-load-more][hidden]) {
    margin-top: 0;
    margin-bottom: var(--spacing-6);
  }

  #shopify-section-{{ section.id }} .subcollection-load-more__button {
    min-width: 180px;
  }

  #shopify-section-{{ section.id }} .subcollection-load-more__loading {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  #shopify-section-{{ section.id }} .subcollection-load-more__spinner {
    width: 1em;
    height: 1em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 999px;
    display: inline-block;
    animation: subcollectionSpin 0.8s linear infinite;
  }

  @keyframes subcollectionSpin {
    to { transform: rotate(360deg); }
  }

  @media screen and (max-width: 699px) {
    #shopify-section-{{ section.id }} .subcollection-load-more__footer {
      margin-top: var(--spacing-3);
      margin-bottom: var(--spacing-8);
    }
  }
</style>

<div class="container">
  {%- if model_blocks.size > 0 and section.settings.show_shop_by_model -%}
    <div class="page-bundle-shop-by-model">
      {%- if section.settings.shop_by_model_heading != blank -%}
        <h2 class="page-bundle-shop-by-model__heading">{{ section.settings.shop_by_model_heading | escape }}</h2>
      {%- endif -%}

      <div class="page-bundle-shop-by-model__grid">
        {%- for block in model_blocks -%}
          {%- if block.settings.label == blank -%}
            {%- continue -%}
          {%- endif -%}

          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="page-bundle-shop-by-model__item" {{ block.shopify_attributes }}>
          {%- else -%}
            <div class="page-bundle-shop-by-model__item" {{ block.shopify_attributes }}>
          {%- endif -%}
            <div class="page-bundle-shop-by-model__image-wrap">
              {%- if block.settings.image != blank -%}
                {{- block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'page-bundle-shop-by-model__image', widths: '200,300,400,500,600', sizes: '(max-width: 699px) 40vw, 220px' -}}
              {%- else -%}
                {{- 'product-1' | placeholder_svg_tag: 'page-bundle-shop-by-model__image' -}}
              {%- endif -%}
            </div>
            <p class="page-bundle-shop-by-model__label">{{ block.settings.label | escape }}</p>
          {%- if block.settings.link != blank -%}
            </a>
          {%- else -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  {%- if has_groups -%}
    <div class="collection collection-subcollections">
      <div class="collection-subcollections__layout">
        <div class="collection-subcollections__mobile">
          <button type="button" class="collection-subcollections__mobile-toggle" aria-controls="subcollections-drawer" aria-expanded="false">
            <span class="sr-only">Open section navigation</span>
            {%- render 'icon' with 'hamburger' -%}
          </button>

          <div class="collection-subcollections__mobile-overlay" data-subcollections-close hidden></div>
          <aside id="subcollections-drawer" class="collection-subcollections__mobile-drawer" role="dialog" aria-modal="true" aria-label="Section navigation" hidden>
            <div class="collection-subcollections__mobile-drawer-header">
              <p class="bold">Menu</p>
              <button type="button" class="tap-area" data-subcollections-close aria-label="Close menu">
                {%- render 'icon' with 'close' -%}
              </button>
            </div>
            <div class="collection-subcollections__mobile-menu">
              <nav class="collection-subcollections__nav collection-subcollections__nav--mobile">
                {%- for block in group_blocks -%}
                  {%- if block.settings.title == blank or block.settings.collection == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  <a class="collection-subcollections__nav-link" href="#sub-{{ block.id }}">{{ block.settings.title | escape }}</a>
                {%- endfor -%}
              </nav>

              <div class="collection-subcollections__dots" aria-hidden="true">
                {%- for block in group_blocks -%}
                  {%- if block.settings.title == blank or block.settings.collection == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  <span class="collection-subcollections__dot" data-subcollections-dot="#sub-{{ block.id }}"></span>
                {%- endfor -%}
              </div>
            </div>
          </aside>
        </div>

        <div class="collection-subcollections__main">
          {%- for block in group_blocks -%}
            {%- if block.settings.title == blank or block.settings.collection == blank -%}
              {%- continue -%}
            {%- endif -%}

            {%- assign group_collection = block.settings.collection -%}
            {%- if group_collection.products_count == 0 -%}
              {%- continue -%}
            {%- endif -%}

            <section id="sub-{{ block.id }}" class="collection-subcollections__group" {{ block.shopify_attributes }}>
              <h2 class="collection-subcollections__title">{{ block.settings.title | escape }}</h2>

              {%- if block.settings.description != blank -%}
                <div class="prose text-subdued" style="margin: -24px auto 32px; max-width: 920px; text-align: center;">
                  {{ block.settings.description }}
                </div>
              {%- endif -%}

              <subcollection-load-more class="subcollection-load-more v-stack gap-6" data-step="{{ block.settings.load_more_step | default: section.settings.load_more_step }}">
                <reveal-items selector=".product-list > *">
                  <product-list class="product-list" role="region" aria-live="polite" data-items>
                    {%- assign position = 0 -%}
                    {%- assign render_index = 0 -%}
                    {%- assign initial_count = block.settings.load_more_step | default: section.settings.load_more_step -%}

                    {%- for product in group_collection.products -%}
                      {%- assign position = position | plus: 1 -%}
                      {%- assign render_index = render_index | plus: 1 -%}
                      <div {% if render_index > initial_count %}hidden data-hidden-item{% endif %}>
                        {%- render 'product-card', product: product, stacked: true, position: position, show_badges: true -%}
                      </div>
                    {%- endfor -%}
                  </product-list>
                </reveal-items>

                {%- if group_collection.products_count > initial_count -%}
                  <div class="subcollection-load-more__footer">
                    <button type="button" class="button button--lg subcollection-load-more__button" data-load-more>
                      <span data-show-more>{{ section.settings.load_more_label | default: 'Show more' }}</span>
                      <span class="subcollection-load-more__loading" data-loading hidden>
                        <span class="subcollection-load-more__spinner" aria-hidden="true"></span>
                        <span>{{ section.settings.loading_label | default: 'Loading...' }}</span>
                      </span>
                    </button>
                  </div>
                {%- endif -%}
              </subcollection-load-more>
            </section>
          {%- endfor -%}
        </div>

        <aside class="collection-subcollections__sidebar" aria-label="Page section navigation">
          <div class="collection-subcollections__sidebar-inner">
            <div class="collection-subcollections__sidebar-menu">
              <nav class="collection-subcollections__nav">
                {%- for block in group_blocks -%}
                  {%- if block.settings.title == blank or block.settings.collection == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  <a class="collection-subcollections__nav-link" href="#sub-{{ block.id }}">{{ block.settings.title | escape }}</a>
                {%- endfor -%}
              </nav>

              <div class="collection-subcollections__dots collection-subcollections__dots--desktop" aria-hidden="true">
                {%- for block in group_blocks -%}
                  {%- if block.settings.title == blank or block.settings.collection == blank -%}
                    {%- continue -%}
                  {%- endif -%}
                  <span class="collection-subcollections__dot" data-subcollections-dot="#sub-{{ block.id }}"></span>
                {%- endfor -%}
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  {%- elsif model_blocks.size == 0 -%}
    <div class="empty-state">
      <div class="prose">
        <p class="h5">Add Shop by Model items or Product group blocks in the theme editor.</p>
      </div>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Bundle page navigation",
  "class": "shopify-section--page-bundle-nav",
  "tag": "section",
  "max_blocks": 30,
  "settings": [
    {
      "type": "header",
      "content": "Shop by model"
    },
    {
      "type": "checkbox",
      "id": "show_shop_by_model",
      "label": "Show Shop by Model",
      "default": true
    },
    {
      "type": "text",
      "id": "shop_by_model_heading",
      "label": "Shop by Model heading",
      "default": "Shop By Model"
    },
    {
      "type": "range",
      "id": "model_columns_desktop",
      "label": "Model columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "model_columns_mobile",
      "label": "Model columns (mobile)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "Product groups"
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Products per row (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3
    },
    {
      "type": "range",
      "id": "load_more_step",
      "label": "Products shown before Load more",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load more button label",
      "default": "Show more"
    },
    {
      "type": "text",
      "id": "loading_label",
      "label": "Loading label",
      "default": "Loading..."
    }
  ],
  "blocks": [
    {
      "type": "model_item",
      "name": "Shop by model item",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Link text",
          "default": "Model name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    },
    {
      "type": "product_group",
      "name": "Product group",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Section title",
          "default": "Section name"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description (optional)"
        },
        {
          "type": "range",
          "id": "load_more_step",
          "label": "Products shown before Load more",
          "min": 2,
          "max": 24,
          "step": 1,
          "default": 6,
          "info": "Leave default to use section setting"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Bundle page navigation",
      "blocks": [
        {
          "type": "model_item",
          "settings": {
            "label": "Mini"
          }
        },
        {
          "type": "model_item",
          "settings": {
            "label": "Gen 3"
          }
        },
        {
          "type": "model_item",
          "settings": {
            "label": "Gen 3P"
          }
        },
        {
          "type": "model_item",
          "settings": {
            "label": "Gen 2"
          }
        },
        {
          "type": "product_group",
          "settings": {
            "title": "Product group 1"
          }
        }
      ]
    }
  ]
}
{% endschema %}

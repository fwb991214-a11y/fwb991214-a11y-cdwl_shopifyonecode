          "label": "Title",
          "default": "Safety"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "What Drives Us"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Parts4Star designs reliable power and accessory solutions for Starlink and advanced mobile technology. Built for vehicles, off-grid use, and real-world conditions, our products focus on safety, stability, and smart engineering-so your connection stays powered wherever you go.</p>"
    },
    {
      "type": "range",
      "id": "feature_icon_size",

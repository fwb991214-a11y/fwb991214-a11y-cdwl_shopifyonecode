{%- if section.blocks.size > 0 -%}
  {%- render 'section-spacing-collapsing' -%}

  {%- assign carousel_id = 'swiper-image-card-carousel-' | append: section.id -%}

  <style>
    #shopify-section-{{ section.id }} {
      /* Allow carousel to "bleed" outside container, but clip at viewport */
      overflow-x: clip;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel {
      border-radius: var(--rounded-lg, 16px);
      overflow: visible;
      position: relative;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__inner {
      /* Force "content area" to 1440px like the HTML prototype */
      max-width: 1440px;
      margin-inline: auto;
      padding: var(--spacing-10);
    }

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .swiper-image-card-carousel__inner {
        padding: var(--spacing-8);
      }
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__top {
      display: flex;
      align-items: center;
      justify-content: center;
      margin-block-end: var(--spacing-8);
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__title {
      text-align: center;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__slider {
      position: relative;
    }

    /* 1440-based bleed: allow slider to extend to viewport edges */
    #shopify-section-{{ section.id }} .swiper-image-card-carousel__bleed {
      --carousel-bleed: max(0px, calc(((100vw - var(--scrollbar-width, 0px)) - 1440px) / 2));
      scroll-padding-inline: var(--carousel-bleed);
      margin-inline: calc(-1 * var(--carousel-bleed));
      padding-inline: var(--carousel-bleed);
    }

    #shopify-section-{{ section.id }} .swiper {
      overflow: visible;
    }

    #shopify-section-{{ section.id }} .swiper-slide {
      height: auto;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__card {
      border-radius: var(--rounded-lg, 16px);
      overflow: hidden;
      position: relative;
      isolation: isolate;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__card-media {
      aspect-ratio: var(--card-aspect-ratio, 4 / 5);
      width: 100%;
      height: auto;
      object-fit: cover;
      display: block;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__placeholder {
      aspect-ratio: var(--card-aspect-ratio, 4 / 5);
      width: 100%;
      display: grid;
      place-items: center;
      background: rgb(var(--text-color) / 0.06);
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__placeholder svg {
      width: 52%;
      height: auto;
      opacity: 0.75;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__overlay {
      position: absolute;
      inset: 0;
      background: rgb(var(--overlay-color, 0 0 0) / var(--overlay-opacity, 0.25));
      pointer-events: none;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__content {
      position: absolute;
      inset-inline: 0;
      inset-block-start: 0;
      padding: var(--spacing-8);
      display: grid;
      gap: var(--spacing-3);
      align-content: start;
      pointer-events: none;
      color: rgb(var(--card-text-color, 255 255 255));
    }

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .swiper-image-card-carousel__content {
        padding: var(--spacing-6);
      }
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__content .button {
      pointer-events: auto;
      justify-self: start;
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__nav {
      position: absolute;
      inset-inline-end: 0;
      inset-block-end: 0;
      display: flex;
      gap: var(--spacing-3);
      z-index: 5;
    }

    @media screen and (max-width: 699px) {
      #shopify-section-{{ section.id }} .swiper-image-card-carousel__nav {
        inset-block-end: 0;
      }
    }

    #shopify-section-{{ section.id }} .swiper-image-card-carousel__nav .circle-button[disabled] {
      opacity: .4;
    }
  </style>

  <div {% render 'section-properties' %}>
    <div class="section-stack">
      <div {% render 'surface', class: 'swiper-image-card-carousel', background: section.settings.container_background, text_color: section.settings.container_text_color, background_fallback: 'bg-secondary' %}>
        <div class="swiper-image-card-carousel__inner">
          {%- if section.settings.title != blank -%}
            <div class="swiper-image-card-carousel__top">
              <p class="h2 swiper-image-card-carousel__title">{{ section.settings.title | escape }}</p>
            </div>
          {%- endif -%}

          <div class="swiper-image-card-carousel__bleed">
            <swiper-image-card-carousel
              id="{{ carousel_id }}"
              class="swiper-image-card-carousel__slider"
              data-slides-mobile="{{ section.settings.slides_mobile }}"
              data-slides-tablet="{{ section.settings.slides_tablet }}"
              data-slides-desktop="{{ section.settings.slides_desktop }}"
              data-space-between="{{ section.settings.space_between }}"
              data-loop="{{ section.settings.loop }}"
              data-speed="{{ section.settings.speed }}"
            >
              <div class="swiper">
                <div class="swiper-wrapper">
                  {%- for block in section.blocks -%}
                    {%- liquid
                      assign loading_strategy = nil
                      if section.index > 3 or forloop.index > 3
                        assign loading_strategy = 'lazy'
                      endif
                    -%}

                    <div class="swiper-slide" {{ block.shopify_attributes }}>
                      <div
                        class="swiper-image-card-carousel__card"
                        style="
                          --overlay-color: {{ block.settings.overlay_color.rgb }};
                          --overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};
                          --card-text-color: {{ block.settings.text_color.rgb }};
                          --card-aspect-ratio: {{ block.settings.aspect_ratio }};
                        "
                      >
                        {%- if block.settings.image != blank -%}
                          {{- block.settings.image
                            | image_url: width: block.settings.image.width
                            | image_tag:
                              loading: loading_strategy,
                              sizes: '(max-width: 699px) 80vw, (max-width: 999px) 45vw, 25vw',
                              widths: '300,400,500,600,700,800,900,1000,1200,1400,1600,1800,2000',
                              class: 'swiper-image-card-carousel__card-media'
                          -}}
                        {%- else -%}
                          <div class="swiper-image-card-carousel__placeholder">
                            {{- 'image' | placeholder_svg_tag: 'placeholder' -}}
                          </div>
                        {%- endif -%}

                        <div class="swiper-image-card-carousel__overlay"></div>

                        {%- if block.settings.heading != blank or block.settings.text != blank or block.settings.button_text != blank -%}
                          <div class="swiper-image-card-carousel__content">
                            {%- if block.settings.heading != blank -%}
                              <p class="{{ block.settings.heading_tag }}">{{ block.settings.heading | escape }}</p>
                            {%- endif -%}

                            {%- if block.settings.text != blank -%}
                              {{- block.settings.text -}}
                            {%- endif -%}

                            {%- if block.settings.button_text != blank and block.settings.button_link != blank -%}
                              {%- render 'button',
                                href: block.settings.button_link,
                                content: block.settings.button_text,
                                size: 'lg',
                                background: block.settings.button_background,
                                text_color: block.settings.button_text_color
                              -%}
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>

              <div class="swiper-image-card-carousel__nav">
                <button type="button" class="circle-button ring group" data-swiper-prev aria-label="{{ 'general.accessibility.previous' | t }}">
                  <span class="animated-arrow animated-arrow--reverse"></span>
                </button>
                <button type="button" class="circle-button ring group" data-swiper-next aria-label="{{ 'general.accessibility.next' | t }}">
                  <span class="animated-arrow"></span>
                </button>
              </div>
            </swiper-image-card-carousel>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const CSS_URL = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css";
      const JS_URL = "https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js";

      function ensureSwiperAssets() {
        const promises = [];

        if (!document.querySelector('link[data-swiper-bundle]')) {
          const link = document.createElement('link');
          link.rel = 'stylesheet';
          link.href = CSS_URL;
          link.dataset.swiperBundle = 'true';
          document.head.appendChild(link);
        }

        if (window.Swiper) return Promise.resolve();

        let script = document.querySelector('script[data-swiper-bundle]');
        if (!script) {
          script = document.createElement('script');
          script.src = JS_URL;
          script.async = true;
          script.dataset.swiperBundle = 'true';
          document.head.appendChild(script);
        }

        promises.push(new Promise((resolve, reject) => {
          script.addEventListener('load', resolve, { once: true });
          script.addEventListener('error', reject, { once: true });
        }));

        return Promise.all(promises).then(() => {});
      }

      class SwiperImageCardCarousel extends HTMLElement {
        connectedCallback() {
          this._abortController = new AbortController();
          this._init();
        }

        disconnectedCallback() {
          this._abortController?.abort();
          this._destroy();
        }

        async _init() {
          await ensureSwiperAssets().catch(() => {});
          if (!window.Swiper) return;

          const root = this.querySelector('.swiper');
          if (!root || this._swiper) return;

          const slidesMobile = parseFloat(this.dataset.slidesMobile || '1.15');
          const slidesTablet = parseFloat(this.dataset.slidesTablet || '2.2');
          const slidesDesktop = parseFloat(this.dataset.slidesDesktop || '4');
          const spaceBetween = parseInt(this.dataset.spaceBetween || '16', 10);
          const loop = (this.dataset.loop || 'false') === 'true';
          const speed = parseInt(this.dataset.speed || '450', 10);

          const prevEl = this.querySelector('[data-swiper-prev]');
          const nextEl = this.querySelector('[data-swiper-next]');

          this._swiper = new window.Swiper(root, {
            slidesPerView: slidesMobile,
            spaceBetween,
            speed,
            loop,
            watchOverflow: true,
            grabCursor: true,
            observer: true,
            observeParents: true,
            resizeObserver: true,
            navigation: {
              prevEl,
              nextEl
            },
            breakpoints: {
              700: {
                slidesPerView: slidesTablet
              },
              1000: {
                slidesPerView: slidesDesktop
              }
            }
          });

          const updateDisabled = () => {
            if (!prevEl || !nextEl || loop) return;
            prevEl.toggleAttribute('disabled', this._swiper.isBeginning);
            nextEl.toggleAttribute('disabled', this._swiper.isEnd);
          };

          updateDisabled();
          this._swiper.on('slideChange', updateDisabled);
          this._swiper.on('reachBeginning', updateDisabled);
          this._swiper.on('reachEnd', updateDisabled);
          this._swiper.on('fromEdge', updateDisabled);

          if (window.Shopify?.designMode) {
            this.closest('.shopify-section')?.addEventListener('shopify:section:unload', () => this._destroy(), { signal: this._abortController.signal });
          }
        }

        _destroy() {
          if (this._swiper) {
            try { this._swiper.destroy(true, true); } catch (e) {}
            this._swiper = null;
          }
        }
      }

      if (!window.customElements.get('swiper-image-card-carousel')) {
        window.customElements.define('swiper-image-card-carousel', SwiperImageCardCarousel);
      }
    })();
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Swiper image cards",
  "class": "shopify-section--swiper-image-card-carousel",
  "tag": "section",
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "custom.overlay"]
  },
  "max_blocks": 16,
  "settings": [
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Top Collections"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "select",
      "id": "slides_mobile",
      "label": "Slides per view (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.1", "label": "1.1" },
        { "value": "1.15", "label": "1.15" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.3", "label": "1.3" },
        { "value": "1.4", "label": "1.4" },
        { "value": "1.5", "label": "1.5" },
        { "value": "1.6", "label": "1.6" },
        { "value": "1.75", "label": "1.75" },
        { "value": "2", "label": "2" }
      ],
      "default": "1.15"
    },
    {
      "type": "select",
      "id": "slides_tablet",
      "label": "Slides per view (tablet)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "1.2", "label": "1.2" },
        { "value": "1.5", "label": "1.5" },
        { "value": "2", "label": "2" },
        { "value": "2.2", "label": "2.2" },
        { "value": "2.5", "label": "2.5" },
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3.5" },
        { "value": "4", "label": "4" }
      ],
      "default": "2.2"
    },
    {
      "type": "select",
      "id": "slides_desktop",
      "label": "Slides per view (desktop)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "2.5", "label": "2.5" },
        { "value": "3", "label": "3" },
        { "value": "3.5", "label": "3.5" },
        { "value": "4", "label": "4" },
        { "value": "4.5", "label": "4.5" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "space_between",
      "label": "Gap between slides",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Transition speed",
      "min": 150,
      "max": 1200,
      "step": 50,
      "unit": "ms",
      "default": 450
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop slides",
      "default": false
    },
    {
      "type": "header",
      "content": "Container colors"
    },
    {
      "type": "color",
      "id": "container_background",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "container_text_color",
      "label": "Text",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Image card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "Image ratio",
          "options": [
            { "value": "1 / 1", "label": "Square (1:1)" },
            { "value": "4 / 5", "label": "Portrait (4:5)" },
            { "value": "3 / 4", "label": "Portrait (3:4)" },
            { "value": "16 / 9", "label": "Landscape (16:9)" }
          ],
          "default": "4 / 5"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Mini for Camping"
        },
        {
          "type": "select",
          "id": "heading_tag",
          "label": "Heading size",
          "options": [
            { "value": "h2", "label": "Large" },
            { "value": "h3", "label": "Medium" },
            { "value": "h4", "label": "Small" }
          ],
          "default": "h3"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Use Starlink Mini anytime, anywhere</p>"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "header",
          "content": "Card colors"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "overlay_color",
          "label": "Overlay",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 25
        },
        {
          "type": "header",
          "content": "Button colors"
        },
        {
          "type": "color",
          "id": "button_background",
          "label": "Button background",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Swiper image cards",
      "category": "Media",
      "blocks": [
        { "type": "card" },
        { "type": "card" },
        { "type": "card" },
        { "type": "card" }
      ]
    }
  ]
}
{% endschema %}
